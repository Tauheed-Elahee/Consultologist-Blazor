<FluentDesignTheme @ref="@_theme" Mode="@_themeMode" StorageName="consultologist-clinical-theme" />

<FluentHeader Class="app-header">
    <FluentStack Class="app-header__inner"
                 Orientation="Orientation.Horizontal"
                 VerticalAlignment="VerticalAlignment.Center"
                 Width="100%">
        <a class="brand-lockup" href="/">
            <img src="icon.png" alt="" />
            <span class="brand-name">Consultologist</span>
        </a>
        <nav class="top-nav" aria-label="Workspace navigation">
            <FluentNavLink Href="/" Match="NavLinkMatch.All">Home</FluentNavLink>
            <AuthorizeView>
                <Authorized>
                    <FluentNavLink Href="profile">Profile</FluentNavLink>
                    <FluentNavLink Href="history">History</FluentNavLink>
                    <FluentNavLink Href="templates">Templates</FluentNavLink>
                    <FluentNavLink Href="consults">Consults</FluentNavLink>
                </Authorized>
            </AuthorizeView>
        </nav>
        <FluentSpacer />
        <FluentStack Class="app-header__actions"
                     Orientation="Orientation.Horizontal"
                     HorizontalGap="12"
                     VerticalAlignment="VerticalAlignment.Center">
            <FluentButton IconStart="@_themeIcon"
                          Appearance="Appearance.Stealth"
                          Title="Toggle theme"
                          OnClick="@ToggleTheme" />
            <LoginDisplay />
        </FluentStack>
    </FluentStack>
</FluentHeader>

@code {
    private FluentDesignTheme? _theme;
    private DesignThemeModes _themeMode = DesignThemeModes.System;

    private Icon _themeIcon => _themeMode == DesignThemeModes.Dark
        ? new Icons.Regular.Size20.WeatherSunny()
        : new Icons.Regular.Size20.WeatherMoon();

    private void ToggleTheme()
    {
        _themeMode = _themeMode == DesignThemeModes.Dark
            ? DesignThemeModes.Light
            : DesignThemeModes.Dark;
    }
}
