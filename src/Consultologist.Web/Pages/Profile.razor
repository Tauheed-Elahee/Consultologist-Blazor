@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@inject IAccountEndpointService AccountService
@inject NavigationManager Navigation
@attribute [Authorize]

@page "/profile"

<PageTitle>Profile</PageTitle>

<section class="page-header">
    <div class="page-header__content">
        <span class="section-eyebrow">Profile</span>
        <h1 class="page-title">Workspace identity.</h1>
        <p class="page-description">
            Confirm the signed-in account used for protected Consultologist workflows and Microsoft identity access.
        </p>
    </div>
</section>

<AuthorizeView>
    <Authorized>
        @if (account != null)
        {
            <section class="content-card">
                <div class="form-stack">
                    <h2 class="panel-title">
                        Signed-in account details
                    </h2>

                    <p class="panel-description">
                        These details come from the Consultologist account service for the current clinician session.
                    </p>

                    <div class="state-panel">
                        <span class="muted-text">Display name</span>
                        <strong>@account.DisplayName</strong>
                    </div>

                    <div class="state-panel">
                        <span class="muted-text">Email</span>
                        <strong>@(account.Email ?? "Not provided")</strong>
                    </div>

                    <div class="state-panel">
                        <span class="muted-text">App user ID</span>
                        <strong>@account.AppUserId</strong>
                    </div>

                    <div class="state-panel">
                        <span class="muted-text">Current identity</span>
                        <strong>@account.CurrentIdentity.Provider</strong>
                    </div>

                    <FluentMessageBar Intent="MessageIntent.Info">
                        Protected API requests use this account identity for server-side authorization and job ownership.
                    </FluentMessageBar>
                </div>
            </section>

            <section class="content-card">
                <div class="form-stack">
                    <h2 class="panel-title">
                        LinkedIn verification
                    </h2>

                    <p class="panel-description">
                        Connecting your LinkedIn profile proves this account belongs to a real clinician.
                        It supports the account activation decision — LinkedIn is never used to sign in.
                    </p>

                    @if (linkedInMessage != null)
                    {
                        <FluentMessageBar Intent="@linkedInMessageIntent">@linkedInMessage</FluentMessageBar>
                    }

                    @if (LinkedInIdentity != null)
                    {
                        <div class="state-panel">
                            <span class="muted-text">Connected LinkedIn profile</span>
                            <strong>@(LinkedInIdentity.DisplayName ?? "LinkedIn account")</strong>
                            @if (LinkedInIdentity.Email != null)
                            {
                                <span class="muted-text">@LinkedInIdentity.Email</span>
                            }
                            @if (VerifiedCategoryLabels.Length > 0)
                            {
                                <strong>Verified on LinkedIn: @string.Join(", ", VerifiedCategoryLabels)</strong>
                            }
                            <span class="muted-text">Connected @LinkedInIdentity.LinkedAt.ToString("yyyy-MM-dd")</span>
                        </div>
                    }

                    <div class="action-row">
                        <FluentButton Appearance="Appearance.Accent"
                                      IconStart="@(new Icons.Regular.Size20.LinkMultiple())"
                                      Disabled="@linkedInStartInProgress"
                                      @onclick="ConnectLinkedInAsync">
                            @(LinkedInIdentity == null ? "Connect LinkedIn" : "Reconnect LinkedIn")
                        </FluentButton>
                    </div>
                </div>
            </section>
        }
        else if (!string.IsNullOrWhiteSpace(accountErrorMessage))
        {
            <section class="state-panel">
                <FluentMessageBar Intent="MessageIntent.Error">@accountErrorMessage</FluentMessageBar>
            </section>
        }
        else
        {
            <section class="state-panel">
                <div class="loading-state">
                    <FluentProgressRing />
                    <span>Loading profile information...</span>
                </div>
            </section>
        }

    </Authorized>
</AuthorizeView>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    [SupplyParameterFromQuery(Name = "linkedin")]
    private string? LinkedInResult { get; set; }

    [SupplyParameterFromQuery(Name = "reason")]
    private string? LinkedInErrorReason { get; set; }

    private AccountMeResponse? account;
    private string? accountErrorMessage;
    private string? linkedInMessage;
    private MessageIntent linkedInMessageIntent = MessageIntent.Info;
    private bool linkedInStartInProgress;

    private AccountIdentity? LinkedInIdentity =>
        account?.LinkedIdentities.FirstOrDefault(identity =>
            string.Equals(identity.Provider, "linkedin", StringComparison.Ordinal));

    private string[] VerifiedCategoryLabels =>
        (LinkedInIdentity?.VerifiedCategories ?? string.Empty)
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(category => category switch
            {
                "IDENTITY" => "Identity",
                "WORKPLACE" => "Workplace",
                _ => category
            })
            .ToArray();

    protected override async Task OnInitializedAsync()
    {
        CaptureLinkedInResultFromQuery();

        var authState = await AuthenticationStateTask!;
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            return;
        }

        await LoadAccountAsync();
    }

    private void CaptureLinkedInResultFromQuery()
    {
        if (string.IsNullOrWhiteSpace(LinkedInResult))
        {
            return;
        }

        (linkedInMessage, linkedInMessageIntent) = LinkedInResult switch
        {
            "connected" => ("LinkedIn profile connected.", MessageIntent.Success),
            _ => (LinkedInErrorReason switch
            {
                "denied" => "LinkedIn connection was cancelled or denied.",
                "already-linked" => "That LinkedIn profile is already connected to a different Consultologist account.",
                _ => "LinkedIn connection failed. Please try again."
            }, MessageIntent.Error)
        };

        // Strip the query so a refresh doesn't replay the message.
        Navigation.NavigateTo("/profile", replace: true);
    }

    private async Task LoadAccountAsync()
    {
        try
        {
            account = await AccountService.GetCurrentAccountAsync();
        }
        catch (AccessTokenNotAvailableException exception)
        {
            exception.Redirect();
        }
        catch (Exception ex)
        {
            accountErrorMessage = $"Unable to load account information: {ex.Message}";
        }
    }

    private async Task ConnectLinkedInAsync()
    {
        linkedInStartInProgress = true;

        try
        {
            var authorizationUrl = await AccountService.StartLinkedInLinkAsync();
            Navigation.NavigateTo(authorizationUrl, forceLoad: true);
        }
        catch (AccessTokenNotAvailableException exception)
        {
            exception.Redirect();
        }
        catch (Exception ex)
        {
            linkedInMessage = $"Unable to start the LinkedIn connection: {ex.Message}";
            linkedInMessageIntent = MessageIntent.Error;
            linkedInStartInProgress = false;
        }
    }
}
