@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using Consultologist.Web.Services.Workflow
@inject IWorkflowEndpointService WorkflowService

<PageTitle>Consultologist Clinical Workspace</PageTitle>

<section class="page-header">
    <div class="page-header__content">
        <span class="section-eyebrow">Clinical workspace</span>
        <h1 class="page-title">Consult drafting with traceable clinical context.</h1>
        <p class="page-description">
            Build structured specialist consults from referral details, review the generated note,
            and keep the physician in control before anything reaches the chart. Every consult
            resolves to versioned, inspectable artifacts — the workflow, its rules, and each
            step's provenance.
        </p>
    </div>
</section>

<AuthorizeView>
    <NotAuthorized>
        <PublicChainStrip />
        <section class="content-card">
            <div class="form-stack">
                <h2 class="panel-title">Sign in to continue</h2>
                <p class="panel-description">
                    Access consult drafts, templates, and your clinical workspace profile.
                </p>
                <div class="action-row">
                    <FluentAnchor Appearance="Appearance.Accent" Href="authentication/login">
                        Log in
                    </FluentAnchor>
                </div>
            </div>
        </section>
    </NotAuthorized>
    <Authorized>
        <section class="workflow-grid">
            <div class="content-card">
                <div class="form-stack">
                    <h2 class="panel-title">Start a consult</h2>
                    <p class="panel-description">
                        Enter referral context and generate a draft consultation note for review.
                    </p>
                    <div class="action-row">
                        <FluentAnchor Appearance="Appearance.Accent" Href="consults">
                            Create Consult
                        </FluentAnchor>
                    </div>
                </div>
            </div>
            <div class="content-card">
                <div class="form-stack">
                    <h2 class="panel-title">Edit your workflow</h2>
                    <p class="panel-description">
                        Fork the workflow package behind your consults — prompts and section
                        standards — with every version published and traceable.
                    </p>
                    @if (currentRef != null)
                    {
                        <p class="muted-text">currently: <code>@currentRef</code></p>
                    }
                    <div class="action-row">
                        <FluentAnchor Appearance="Appearance.Outline" Href="templates">
                            Open workflow editor
                        </FluentAnchor>
                    </div>
                </div>
            </div>
            <div class="content-card">
                <div class="form-stack">
                    <h2 class="panel-title">Review history</h2>
                    <p class="panel-description">
                        Every consult job with its full provenance: the package, the catalog,
                        the input and output hashes, and the per-step chain.
                    </p>
                    <div class="action-row">
                        <FluentAnchor Appearance="Appearance.Outline" Href="history">
                            Open history
                        </FluentAnchor>
                    </div>
                </div>
            </div>
        </section>
        <PublicChainStrip />
    </Authorized>
</AuthorizeView>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthenticationState { get; set; }

    private string? currentRef;

    protected override async Task OnInitializedAsync()
    {
        // The pin line is signed-in decoration only: an unauthenticated fetch
        // would redirect a visitor to login, so check the state first.
        if (AuthenticationState == null)
        {
            return;
        }

        var state = await AuthenticationState;

        if (state.User.Identity?.IsAuthenticated != true)
        {
            return;
        }

        try
        {
            currentRef = (await WorkflowService.GetCurrentPackageAsync()).Ref;
        }
        catch (AccessTokenNotAvailableException)
        {
            // Token expired mid-session: the line is decoration, not worth a redirect.
        }
        catch
        {
            // Unreachable package endpoint hides the line; the cards stand alone.
        }
    }
}
