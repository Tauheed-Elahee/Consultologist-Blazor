@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using Consultologist.Web.Services.AI
@using Consultologist.Web.Services.Workflow
@inject IAccountEndpointService AccountService
@inject IAIEndpointService AIService
@inject IWorkflowEndpointService WorkflowService
@attribute [Authorize]

@page "/history"

<PageTitle>History</PageTitle>

<section class="page-header">
    <div class="page-header__content">
        <span class="section-eyebrow">History</span>
        <h1 class="page-title">Consult generation history.</h1>
        <p class="page-description">
            Consult generation jobs started by this account, most recent first.
        </p>
    </div>
</section>

<AuthorizeView>
    <Authorized>
        <section class="content-card">
            <div class="form-stack">
                <h2 class="panel-title">Recent consult jobs</h2>

                @if (jobsLoading && jobs.Count == 0)
                {
                    <div class="loading-state">
                        <FluentProgressRing />
                        <span>Loading job history...</span>
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(jobsErrorMessage))
                {
                    <FluentMessageBar Intent="MessageIntent.Error">@jobsErrorMessage</FluentMessageBar>
                }
                else if (jobs.Count == 0)
                {
                    <p class="muted-text">No consult jobs found.</p>
                }
                else
                {
                    <div class="job-history-list">
                        @foreach (var job in jobs)
                        {
                            <details class="job-item">
                                <summary class="job-item__summary" @onclick="async () => await EnsureDetailsLoadedAsync(job.JobId)">
                                    <span class="job-item__chevron" aria-hidden="true">&#x203A;</span>
                                    <div class="job-history-item__status">
                                        <span class="job-status-badge job-status-badge--@job.Status.ToLowerInvariant()">
                                            @job.Status
                                        </span>
                                    </div>
                                    <div class="job-history-item__meta">
                                        <span class="muted-text">@FormatDate(job.CreatedAtUtc)</span>
                                        <span class="muted-text">@job.CompletedBlockCount / @job.TotalBlockCount sections</span>
                                        @if (job.FailedBlockCount > 0)
                                        {
                                            <span class="muted-text">@job.FailedBlockCount failed</span>
                                        }
                                    </div>
                                    <div class="job-history-item__id">
                                        <span class="muted-text">@job.JobId[..8]&hellip;</span>
                                    </div>
                                </summary>
                                <div class="job-item__detail">
                                    @{
                                        var hasStartedLoad = _jobDetails.TryGetValue(job.JobId, out var detail);
                                        _jobDetailErrors.TryGetValue(job.JobId, out var detailError);
                                    }
                                    @if (!hasStartedLoad)
                                    {
                                        @* Rendered but empty until first expand *@
                                    }
                                    else if (!string.IsNullOrWhiteSpace(detailError))
                                    {
                                        <FluentMessageBar Intent="MessageIntent.Error">@detailError</FluentMessageBar>
                                    }
                                    else if (detail == null)
                                    {
                                        <div class="loading-state">
                                            <FluentProgressRing />
                                            <span>Loading job events&hellip;</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="provenance-chips">
                                            <span class="provenance-chip @(IsFork(detail.WorkflowPackage) ? "provenance-chip--fork" : "")"
                                                  title="Workflow package this job ran">
                                                @(detail.WorkflowPackage ?? "—")
                                            </span>
                                            <span class="provenance-chip" title="Output-contract catalog version this job ran under">
                                                @(detail.CatalogRef ?? "catalog —")
                                            </span>
                                            <span class="provenance-chip" title="Job record schema version">
                                                schema v@(detail.SchemaVersion?.ToString() ?? "—")
                                            </span>
                                        </div>

                                        <details class="job-detail-section">
                                            <summary class="muted-text">Provenance</summary>
                                            <dl class="provenance-list">
                                                <dt>Input hash (v@(detail.EffectiveInputHashVersion?.ToString() ?? "—"))</dt>
                                                <dd class="hash-text">@(detail.EffectiveInputHash ?? "—")</dd>
                                                @if (detail.WorkflowOutputHash != null)
                                                {
                                                    <dt>Output hash (v@(detail.WorkflowOutputHashVersion?.ToString() ?? "—"))</dt>
                                                    <dd class="hash-text">@detail.WorkflowOutputHash</dd>
                                                }
                                                @if (LineageFor(detail.WorkflowPackage) is { Count: > 1 } lineage)
                                                {
                                                    <dt>Lineage</dt>
                                                    <dd class="hash-text">@string.Join(" → ", lineage)</dd>
                                                }
                                                @if (AgentContracts(detail).Any())
                                                {
                                                    <dt>Agents</dt>
                                                    <dd>
                                                        @string.Join(" · ", AgentContracts(detail).Select(contract => AgentLine(contract, detail)))
                                                    </dd>
                                                }
                                            </dl>
                                        </details>

                                        var nodeGroups = BuildNodeGroups(detail);
                                            var setupBadge = detail.StartedAtUtc != null
                                                ? ("✓", "node-status--success")
                                                : ("·", "node-status--muted");
                                            var doneBadge = detail.Status switch
                                            {
                                                "Completed" => ("✓", "Done", "node-status--success"),
                                                "Failed" => ("✗", "Failed", "node-status--failure"),
                                                _ => ("●", detail.Status, "node-status--muted")
                                            };
                                        <details class="job-detail-section" open>
                                            <summary class="muted-text">Workflow (@nodeGroups.Count nodes)</summary>
                                            <div class="node-grid">
                                                <div class="node-row">
                                                    <span class="node-row__chevron" aria-hidden="true"></span>
                                                    <span class="node-row__status @setupBadge.Item2">@setupBadge.Item1</span>
                                                    <span class="node-row__label">Setup</span>
                                                    <span class="node-row__contract muted-text">
                                                        created @FormatDate(detail.CreatedAtUtc ?? default)@(detail.StartedAtUtc != null ? $" · started {FormatDate(detail.StartedAtUtc.Value)}" : "")
                                                    </span>
                                                    <span class="node-row__hashes hash-text">
                                                        <span title="@detail.EffectiveInputHash">in @HashPrefix(detail.EffectiveInputHash)</span>
                                                    </span>
                                                </div>
                                                @foreach (var group in nodeGroups)
                                                {
                                                        @if (group.Items.Count == 0)
                                                        {
                                                            <div class="node-row">
                                                                <span class="node-row__chevron" aria-hidden="true"></span>
                                                                <span class="node-row__status @StatusCss(group.NodeLevel?.Status)">@StatusGlyph(group.NodeLevel?.Status)</span>
                                                                <span class="node-row__label">@group.Descriptor.Label</span>
                                                                <span class="node-row__contract muted-text">@ContractLabel(group.Descriptor, detail)</span>
                                                                <span class="node-row__hashes hash-text">
                                                                    <span title="@group.NodeLevel?.InputHash">in @HashPrefix(group.NodeLevel?.InputHash)</span>
                                                                    <span title="@group.NodeLevel?.OutputHash">out @HashPrefix(group.NodeLevel?.OutputHash)</span>
                                                                </span>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <details class="node-group">
                                                                <summary class="node-row">
                                                                    <span class="node-row__chevron" aria-hidden="true">&#x203A;</span>
                                                                    <span class="node-row__status @StatusCss(group.NodeLevel?.Status)">@StatusGlyph(group.NodeLevel?.Status)</span>
                                                                    <span class="node-row__label">@group.Descriptor.Label</span>
                                                                    <span class="node-row__contract muted-text">
                                                                        @ContractLabel(group.Descriptor, detail) · per @group.Descriptor.ForEach item (@group.Items.Count)
                                                                    </span>
                                                                </summary>
                                                                @foreach (var (itemId, entry) in group.Items)
                                                                {
                                                                    <div class="node-row node-row--item">
                                                                        <span class="node-row__chevron" aria-hidden="true"></span>
                                                                        <span class="node-row__status @StatusCss(entry.Status)">@StatusGlyph(entry.Status)</span>
                                                                        <span class="node-row__label">@itemId</span>
                                                                        <span class="node-row__hashes hash-text">
                                                                            <span title="@entry.InputHash">in @HashPrefix(entry.InputHash)</span>
                                                                            <span title="@entry.OutputHash">out @HashPrefix(entry.OutputHash)</span>
                                                                            @if (entry.OutputHash != null && group.ConvergedOutputs.Contains(entry.OutputHash))
                                                                            {
                                                                                <span class="muted-text" title="Another item in this node produced the byte-identical output">= same output</span>
                                                                            }
                                                                        </span>
                                                                    </div>
                                                                }
                                                            </details>
                                                        }
                                                }
                                                <div class="node-row">
                                                    <span class="node-row__chevron" aria-hidden="true"></span>
                                                    <span class="node-row__status @doneBadge.Item3">@doneBadge.Item1</span>
                                                    <span class="node-row__label">@doneBadge.Item2</span>
                                                    <span class="node-row__contract muted-text">
                                                        @(detail.CompletedAtUtc != null ? FormatDate(detail.CompletedAtUtc.Value) : "")
                                                        @(detail.RuntimeFailureError != null ? $" · {detail.RuntimeFailureError}" : "")
                                                    </span>
                                                    @if (detail.WorkflowOutputHash != null)
                                                    {
                                                        <span class="node-row__hashes hash-text">
                                                            <span title="@detail.WorkflowOutputHash">out @HashPrefix(detail.WorkflowOutputHash)</span>
                                                        </span>
                                                    }
                                                </div>
                                            </div>
                                        </details>
                                    }
                                </div>
                            </details>
                        }
                    </div>

                    @if (jobsContinuationToken != null)
                    {
                        <FluentButton
                            Appearance="Appearance.Outline"
                            Disabled="@jobsLoading"
                            OnClick="LoadMoreJobsAsync">
                            @if (jobsLoading)
                            {
                                <FluentProgressRing style="width: 16px; height: 16px;" />
                                <span>Loading&hellip;</span>
                            }
                            else
                            {
                                <span>Load more</span>
                            }
                        </FluentButton>
                    }
                }
            </div>
        </section>
    </Authorized>
</AuthorizeView>

@code {
    private List<AccountJobSummaryResponse> jobs = new();
    private string? jobsContinuationToken;
    private bool jobsLoading;
    private string? jobsErrorMessage;

    private Dictionary<string, ConsultGenerationJobResponse?> _jobDetails = new();
    private Dictionary<string, string?> _jobDetailErrors = new();

    // Contract id → agent name, decorated from the anonymous Public/Chain view
    // (the job record stores contract → version only; names are catalog metadata).
    private Dictionary<string, string> _agentNames = new(StringComparer.Ordinal);

    protected override async Task OnInitializedAsync()
    {
        await LoadJobsAsync();
        await LoadAgentNamesAsync();
    }

    private async Task LoadAgentNamesAsync()
    {
        var chain = await WorkflowService.GetPublicChainAsync();
        var contracts = chain?.OutputContracts?.Contracts;

        if (contracts == null)
        {
            return;
        }

        _agentNames = contracts
            .Where(pair => !string.IsNullOrWhiteSpace(pair.Value.AgentName))
            .ToDictionary(pair => pair.Key, pair => pair.Value.AgentName!, StringComparer.Ordinal);
        await InvokeAsync(StateHasChanged);
    }

    // Lineage chains per package ref, from the authorized lineage endpoint;
    // fetched lazily when a detail expands, cached for the page's lifetime.
    private readonly Dictionary<string, IReadOnlyList<string>?> _lineageCache = new(StringComparer.Ordinal);

    private IReadOnlyList<string>? LineageFor(string? packageRef) =>
        packageRef != null && _lineageCache.TryGetValue(packageRef, out var chain) ? chain : null;

    private async Task EnsureLineageLoadedAsync(string? packageRef)
    {
        if (packageRef == null || _lineageCache.ContainsKey(packageRef))
        {
            return;
        }

        _lineageCache[packageRef] = await WorkflowService.GetLineageAsync(packageRef);
        await InvokeAsync(StateHasChanged);
    }

    // Per-version catalog documents, fetched from the public registry — the
    // job's own catalogRef resolves to historically exact agent identities
    // (#105: purified records carry no agentVersions map).
    private readonly Dictionary<string, Dictionary<string, PublicCatalogEntry>?> _catalogCache = new(StringComparer.Ordinal);

    private const string CatalogRefPrefix = "output-contracts@";

    private async Task EnsureCatalogLoadedAsync(string? catalogRef)
    {
        if (catalogRef == null || !catalogRef.StartsWith(CatalogRefPrefix, StringComparison.Ordinal))
        {
            return;
        }

        var version = catalogRef[CatalogRefPrefix.Length..];

        if (_catalogCache.ContainsKey(version))
        {
            return;
        }

        // Only cache success: a failed fetch (transient, or blocked before #122's
        // CSP fix) retries on the next expansion instead of poisoning the session.
        var document = await WorkflowService.GetCatalogAsync(version);

        if (document != null)
        {
            _catalogCache[version] = document;
        }

        await InvokeAsync(StateHasChanged);
    }

    private Dictionary<string, PublicCatalogEntry>? JobCatalog(ConsultGenerationJobResponse detail) =>
        detail.CatalogRef != null
            && detail.CatalogRef.StartsWith(CatalogRefPrefix, StringComparison.Ordinal)
            && _catalogCache.TryGetValue(detail.CatalogRef[CatalogRefPrefix.Length..], out var doc)
            ? doc
            : null;

    private IEnumerable<string> AgentContracts(ConsultGenerationJobResponse detail)
    {
        var contracts = JobCatalog(detail)?.Keys ?? detail.AgentVersions?.Keys as IEnumerable<string>;
        return (contracts ?? Enumerable.Empty<string>()).OrderBy(c => c, StringComparer.Ordinal);
    }

    // Resolution order: the job's own catalog document (historically exact) →
    // the legacy stored map decorated with current-chain names → nothing.
    private (string? Name, string? Version) ResolveAgent(string contract, ConsultGenerationJobResponse detail)
    {
        if (JobCatalog(detail) is { } doc && doc.TryGetValue(contract, out var entry))
        {
            return (entry.AgentName, entry.AgentVersion);
        }

        if (detail.AgentVersions != null && detail.AgentVersions.TryGetValue(contract, out var version))
        {
            return (_agentNames.GetValueOrDefault(contract), version);
        }

        return (null, null);
    }

    private string AgentLine(string contract, ConsultGenerationJobResponse detail) => ResolveAgent(contract, detail) switch
    {
        (string name, string version) => $"{contract} → {name} v{version}",
        (null, string version) => $"{contract} → v{version}",
        _ => contract
    };

    private async Task LoadJobsAsync()
    {
        jobsLoading = true;
        jobsErrorMessage = null;

        try
        {
            var result = await AccountService.GetJobsAsync(limit: 20);
            jobs.AddRange(result.Jobs);
            jobsContinuationToken = result.ContinuationToken;
        }
        catch (AccessTokenNotAvailableException exception)
        {
            exception.Redirect();
        }
        catch (Exception ex)
        {
            jobsErrorMessage = $"Unable to load job history: {ex.Message}";
        }
        finally
        {
            jobsLoading = false;
        }
    }

    private async Task LoadMoreJobsAsync()
    {
        if (jobsLoading || jobsContinuationToken == null)
        {
            return;
        }

        jobsLoading = true;
        StateHasChanged();

        try
        {
            var result = await AccountService.GetJobsAsync(limit: 20, continuationToken: jobsContinuationToken);
            jobs.AddRange(result.Jobs);
            jobsContinuationToken = result.ContinuationToken;
        }
        catch (Exception ex)
        {
            jobsErrorMessage = $"Unable to load more jobs: {ex.Message}";
        }
        finally
        {
            jobsLoading = false;
            StateHasChanged();
        }
    }

    private async Task EnsureDetailsLoadedAsync(string jobId)
    {
        if (_jobDetails.ContainsKey(jobId))
        {
            return;
        }

        _jobDetails[jobId] = null;
        _jobDetailErrors.Remove(jobId);

        try
        {
            var detail = await AIService.GetConsultGenerationJobAsync(jobId);
            _jobDetails[jobId] = detail;
            await EnsureCatalogLoadedAsync(detail?.CatalogRef);
            await EnsureLineageLoadedAsync(detail?.WorkflowPackage);
        }
        catch (AccessTokenNotAvailableException exception)
        {
            exception.Redirect();
        }
        catch (Exception ex)
        {
            _jobDetailErrors[jobId] = $"Unable to load job events: {ex.Message}";
        }

        await InvokeAsync(StateHasChanged);
    }


    private static string FormatDate(DateTimeOffset date)
    {
        var ago = DateTimeOffset.UtcNow - date;

        return ago.TotalMinutes < 1 ? "just now"
            : ago.TotalHours < 1 ? $"{(int)ago.TotalMinutes}m ago"
            : ago.TotalDays < 1 ? $"{(int)ago.TotalHours}h ago"
            : ago.TotalDays < 7 ? $"{(int)ago.TotalDays}d ago"
            : date.ToLocalTime().ToString("MMM d, yyyy");
    }

    private static bool IsFork(string? packageRef) =>
        packageRef != null && packageRef.StartsWith("acct-", StringComparison.Ordinal);

    private static string? HashPrefix(string? hash) =>
        string.IsNullOrEmpty(hash) ? "—" : hash[..Math.Min(12, hash.Length)] + "…";

    private static string StatusCss(string? status) => status switch
    {
        "Completed" => "node-status--success",
        "Failed" => "node-status--failure",
        _ => "node-status--muted"
    };

    private static string StatusGlyph(string? status) => status switch
    {
        "Completed" => "✓",
        "Failed" => "✗",
        "Skipped" => "○",
        null => "·",
        _ => "●"
    };

    private string ContractLabel(ConsultGenerationNodeDescriptor descriptor, ConsultGenerationJobResponse detail)
    {
        var contract = descriptor.OutputContract ?? "text";

        return ResolveAgent(contract, detail) switch
        {
            (string name, string version) => $"{contract} · {name} v{version}",
            (null, string version) => $"{contract} · agent v{version}",
            _ => contract
        };
    }

    private sealed record NodeGroup(
        ConsultGenerationNodeDescriptor Descriptor,
        ConsultGenerationNodeStatus? NodeLevel,
        IReadOnlyList<(string ItemId, ConsultGenerationNodeStatus Entry)> Items,
        IReadOnlySet<string> ConvergedOutputs);

    // The chain map keys are "nodeId" (node level) and "nodeId:itemId" (per item);
    // groups follow the Nodes descriptor order — manifest order. Identical
    // OutputHashes within a node's items are the convergence signal.
    private static IReadOnlyList<NodeGroup> BuildNodeGroups(ConsultGenerationJobResponse detail)
    {
        if (detail.Nodes is not { Count: > 0 } || detail.NodeOutputs is not { Count: > 0 })
        {
            return Array.Empty<NodeGroup>();
        }

        var groups = new List<NodeGroup>();

        foreach (var descriptor in detail.Nodes)
        {
            detail.NodeOutputs.TryGetValue(descriptor.Id, out var nodeLevel);

            var items = detail.NodeOutputs
                .Where(pair => pair.Key.StartsWith(descriptor.Id + ":", StringComparison.Ordinal))
                .Select(pair => (ItemId: pair.Key[(descriptor.Id.Length + 1)..], Entry: pair.Value))
                .OrderBy(pair => pair.ItemId, StringComparer.Ordinal)
                .ToList();

            if (nodeLevel is null && items.Count == 0)
            {
                continue;
            }

            var converged = items
                .Where(pair => pair.Entry.OutputHash != null)
                .GroupBy(pair => pair.Entry.OutputHash!)
                .Where(g => g.Count() > 1)
                .Select(g => g.Key)
                .ToHashSet(StringComparer.Ordinal);

            groups.Add(new NodeGroup(descriptor, nodeLevel, items, converged));
        }

        return groups;
    }




}
