    private readonly Dictionary<string, List<string>> variableAdds = new(StringComparer.Ordinal);
    private readonly Dictionary<string, HashSet<string>> variableRemovals = new(StringComparer.Ordinal);
    private string? newVariableName;
    private string newVariableSource = string.Empty;
    private string? newVariableError;

    private static readonly System.Text.RegularExpressions.Regex VariableNameRegex =
        new("^[a-z][a-z0-9_]*$", System.Text.RegularExpressions.RegexOptions.Compiled);

    private int VariableAddCount => variableAdds.Values.Sum(list => list.Count);

    private int VariableRemovalCount => variableRemovals.Values.Sum(set => set.Count);

    private IReadOnlyList<string> AddedVariables(string? promptId) =>
        promptId != null && variableAdds.TryGetValue(promptId, out var adds) ? adds : Array.Empty<string>();

    private bool IsRemovedVariable(string promptId, string variable) =>
        variableRemovals.TryGetValue(promptId, out var removed) && removed.Contains(variable);

    private bool HasVariableEdits(string promptId) =>
        AddedVariables(promptId).Count > 0
        || (variableRemovals.TryGetValue(promptId, out var removed) && removed.Count > 0);

    private IReadOnlyList<string> EffectiveVariables(WorkflowManifestReader.PromptView prompt)
    {
        var result = prompt.Variables.Where(v => !IsRemovedVariable(prompt.Id, v)).ToList();
        result.AddRange(AddedVariables(prompt.Id));
        return result;
    }

    private bool VariableUsedInText(WorkflowManifestReader.PromptView prompt, string variable) =>
        System.Text.RegularExpressions.Regex.IsMatch(
            GetText(prompt.File),
            @"\{\{\s*" + System.Text.RegularExpressions.Regex.Escape(variable) + @"\s*\}\}");

    private IEnumerable<WorkflowManifestReader.NodeView> NodesUsingPrompt(string promptId) =>
        EffectiveNodes.Where(n => string.Equals(n.Prompt, promptId, StringComparison.Ordinal));

    private string? TryDeclareVariable(string promptId, string rawName, out string name)
    {
        name = rawName.Trim();

        if (!VariableNameRegex.IsMatch(name))
        {
            return "Variable names are lowercase: letters, digits, underscores, starting with a letter.";
        }

        var prompt = EffectivePrompts.FirstOrDefault(p => p.Id == promptId);

        if (prompt == null)
        {
            return "Unknown prompt.";
        }

        if (EffectiveVariables(prompt).Contains(name, StringComparer.Ordinal))
        {
            return $"'{name}' already exists on this prompt.";
        }

        if (!variableAdds.TryGetValue(promptId, out var adds))
        {
            variableAdds[promptId] = adds = new List<string>();
        }

        adds.Add(name);
        return null;
    }

    private async Task AddVariableFromPromptAsync(WorkflowManifestReader.PromptView prompt)
    {
        publishSuccess = null;
        newVariableError = TryDeclareVariable(prompt.Id, newVariableName ?? string.Empty, out var name);

        if (newVariableError != null)
        {
            return;
        }

        // A chosen source is one explicit decision applied to every node using
        // this prompt; left empty, the variable stays unbound everywhere.
        if (!string.IsNullOrEmpty(newVariableSource))
        {
            foreach (var node in NodesUsingPrompt(prompt.Id))
            {
                bindingEdits[BindingKey(node.Id, name)] = (newVariableSource, null);
            }
        }

        newVariableName = null;
        newVariableSource = string.Empty;
        await PersistDraftAsync();
    }

    private WorkflowNodeSummary.BindingRow RowFor(WorkflowManifestReader.NodeView node, string variable)
    {
        var original = node.Bindings.FirstOrDefault(b => b.Variable == variable);
        var effective = GetEffectiveBinding(node.Id, variable) ?? (original?.From ?? string.Empty, original?.As);

        return new WorkflowNodeSummary.BindingRow(
            variable, effective.From, effective.As, original?.From, original?.As, IsNew: original == null);
    }

    private static bool RowModified(WorkflowNodeSummary.BindingRow row) =>
        row.IsNew || row.From != row.OriginalFrom || row.As != row.OriginalAs;

    private IEnumerable<string> FirstUsingNodeOptions(WorkflowManifestReader.PromptView prompt)
    {
        var node = NodesUsingPrompt(prompt.Id).FirstOrDefault();

        return node == null
            ? Enumerable.Empty<string>()
            : BindingSourceEditor.SourceOptions(nodes, scalars, node, string.Empty);
    }

    private async Task RemoveVariableAsync(WorkflowManifestReader.PromptView prompt, string variable)
    {
        publishSuccess = null;

        if (variableAdds.TryGetValue(prompt.Id, out var adds) && adds.Remove(variable))
        {
            if (adds.Count == 0)
            {
                variableAdds.Remove(prompt.Id);
            }
        }
        else
        {
            if (!variableRemovals.TryGetValue(prompt.Id, out var removed))
            {
                variableRemovals[prompt.Id] = removed = new HashSet<string>(StringComparer.Ordinal);
            }

            removed.Add(variable);
        }

        foreach (var node in NodesUsingPrompt(prompt.Id))
        {
            bindingEdits.Remove(BindingKey(node.Id, variable));
        }

        await PersistDraftAsync();
    }

    private async Task RestoreVariableAsync(WorkflowManifestReader.PromptView prompt, string variable)
    {
        publishSuccess = null;

        if (variableRemovals.TryGetValue(prompt.Id, out var removed))
        {
            removed.Remove(variable);

            if (removed.Count == 0)
            {
                variableRemovals.Remove(prompt.Id);
            }
        }

        await PersistDraftAsync();
    }

    private static string BindingKey(string nodeId, string variable) => nodeId + "\n" + variable;

    private (string From, string? As)? GetEffectiveBinding(string nodeId, string variable) =>
        bindingEdits.TryGetValue(BindingKey(nodeId, variable), out var edit) ? edit : null;

    // The Graph cards' effective row model: declared bindings (minus pending
    // removals, with rebinds applied) plus pending-added variables (unbound
    // until a source is chosen).
    // A node whose effective prompt is not the one its manifest bindings were
    // written for (re-pointed via the selector, or born onto an existing
    // prompt): its rows are the new prompt's variables, all unbound until a
    // source is chosen — the old bindings are dead.
    private bool HasFreshBindings(WorkflowManifestReader.NodeView node)
    {
        var manifestNode = nodes.FirstOrDefault(n => n.Id == node.Id);

        if (manifestNode != null)
        {
            return manifestNode.Prompt != null && node.Prompt != null && manifestNode.Prompt != node.Prompt;
        }

        return addedNodes.FirstOrDefault(a => a.Id == node.Id)?.PromptRef != null;
    }

    private IReadOnlyList<WorkflowNodeSummary.BindingRow> RowsFor(WorkflowManifestReader.NodeView node)
    {
        var rows = new List<WorkflowNodeSummary.BindingRow>();

        if (HasFreshBindings(node))
        {
            var prompt = EffectivePrompts.FirstOrDefault(p => p.Id == node.Prompt);

            foreach (var variable in prompt != null ? EffectiveVariables(prompt) : Array.Empty<string>())
            {
                var effective = GetEffectiveBinding(node.Id, variable);
                rows.Add(new WorkflowNodeSummary.BindingRow(variable, effective?.From ?? string.Empty, effective?.As, null, null, true));
            }

            return rows;
        }

        foreach (var binding in node.Bindings)
        {
            if (node.Prompt != null && IsRemovedVariable(node.Prompt, binding.Variable))
            {
                continue;
            }

            rows.Add(RowFor(node, binding.Variable));
        }

        foreach (var variable in AddedVariables(node.Prompt))
        {
            rows.Add(RowFor(node, variable));
        }

        return rows;
    }

    private string? ValidateVariableNameForNode(WorkflowManifestReader.NodeView node, string name)
    {
        if (!VariableNameRegex.IsMatch(name))
        {
            return "Variable names are lowercase: letters, digits, underscores, starting with a letter.";
        }

        var prompt = EffectivePrompts.FirstOrDefault(p => p.Id == node.Prompt);

        if (prompt == null)
        {
            return "This node has no prompt.";
        }

        return EffectiveVariables(prompt).Contains(name, StringComparer.Ordinal)
            ? $"'{name}' already exists on prompt '{prompt.Id}'."
            : null;
    }

    private async Task OnVariableAddedAsync(WorkflowNodeSummary.VariableAdd add)
    {
        publishSuccess = null;
        var node = EffectiveNodes.FirstOrDefault(n => n.Id == add.NodeId);

        if (node?.Prompt == null || TryDeclareVariable(node.Prompt, add.Variable, out var name) != null)
        {
            return;
        }

        // The originating node gets the chosen source (when one was picked);
        // other nodes sharing the prompt start unbound.
        if (!string.IsNullOrEmpty(add.From))
        {
            bindingEdits[BindingKey(node.Id, name)] = (add.From, add.As);
        }

        await PersistDraftAsync();
    }

    private async Task OnBindingChangedAsync(WorkflowNodeSummary.BindingChange change)
    {
        publishSuccess = null;

        var original = nodes.FirstOrDefault(n => n.Id == change.NodeId)?
            .Bindings.FirstOrDefault(b => b.Variable == change.Variable);
        var key = BindingKey(change.NodeId, change.Variable);

        if (original != null && original.From == change.From && original.As == change.As)
        {
            bindingEdits.Remove(key);
        }
        else
        {
            bindingEdits[key] = (change.From, change.As);
        }

        await PersistDraftAsync();
    }

    private bool isLoading;
    private bool isPublishing;
    private string? loadError;
    private string? publishSuccess;
    private List<string> publishErrors = new();

    // Master–detail selection: a file path or GraphKey (#110).
    private string? selectedKey;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private string DraftKey => DraftKeyPrefix + content!.Ref;

    private string? diagramText;
    private bool diagramIncludesPending;
    private bool isDiagramRefreshing;

    private bool HasManifestEdits => bindingEdits.Count > 0 || nodeEdits.Count > 0
        || addedNodes.Count > 0 || removedNodeIds.Count > 0
        || aggregateEdits.Count > 0 || resultEdit != null || addedPrompts.Count > 0
        || VariableAddCount > 0 || VariableRemovalCount > 0;

    private void Select(string key)
    {
        selectedKey = key;

        if (key == GraphKey && diagramText == null)
        {
            _ = LoadDiagramAsync();
        }
    }

    private async Task LoadDiagramAsync()
    {
        diagramText = await WorkflowService.GetCurrentDiagramAsync();
        diagramIncludesPending = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshDiagramAsync()
    {
        if (isDiagramRefreshing)
        {
            return;
        }

        isDiagramRefreshing = true;

        try
        {
            if (HasManifestEdits)
            {
                var diagram = await WorkflowService.GetDiagramForManifestAsync(ComposeManifest());

                if (diagram != null)
                {
                    var (changed, removedEdges, pendingNodes) = CollectDiagramChanges();
                    diagramText = DecoratePendingDiagram(diagram, changed, removedEdges, pendingNodes, removedNodeIds.ToList());
                    diagramIncludesPending = true;
                }
            }
            else
            {
                diagramText = await WorkflowService.GetCurrentDiagramAsync();
                diagramIncludesPending = false;
            }
        }
        catch (AccessTokenNotAvailableException exception)
        {
            exception.Redirect();
        }
        finally
        {
            isDiagramRefreshing = false;
        }
    }

    // The pending diff over the effective diagram: changed pairs draw their
    // edges blue, removed/old edges are re-appended dashed red (they are
    // absent from the effective manifest by definition), and changed nodes
    // keep the blue outline. All presentation, all client-side.
    private (List<(string NodeId, string Variable)> Changed,
             List<(string From, string NodeId, string Variable, bool Rebound)> Removed,
             List<string> PendingNodeIds) CollectDiagramChanges()
    {
        var changed = new List<(string, string)>();
        var removed = new List<(string, string, string, bool)>();
        var pendingNodes = new List<string>();

        foreach (var node in nodes)
        {
            var rows = RowsFor(node);

            if (rows.Any(RowModified))
            {
                pendingNodes.Add(node.Id);
            }

            foreach (var row in rows.Where(RowModified))
            {
                changed.Add((node.Id, row.Variable));

                // A rebound row's old source is an edge that goes away.
                if (!row.IsNew && row.OriginalFrom is { } oldFrom && oldFrom != row.From && IsEdgeSource(oldFrom))
                {
                    removed.Add((oldFrom, node.Id, row.Variable, true));
                }
            }

            // Removed variables' original edges.
            if (node.Prompt != null && variableRemovals.TryGetValue(node.Prompt, out var removedVars))
            {
                foreach (var variable in removedVars)
                {
                    var original = node.Bindings.FirstOrDefault(b => b.Variable == variable);

                    if (original != null && IsEdgeSource(original.From))
                    {
                        removed.Add((original.From, node.Id, variable, false));
                    }
                }
            }
        }

        // Field-edited, aggregate-edited, and freshly added nodes (#117) keep
        // the blue outline; so does a pending deliverable's new target.
        var blueIds = nodeEdits.Keys
            .Concat(aggregateEdits.Keys)
            .Concat(addedNodes.Select(a => a.Id));

        if (resultEdit != null && resultEdit.StartsWith("node:", StringComparison.Ordinal))
        {
            blueIds = blueIds.Append(resultEdit["node:".Length..]);
        }

        foreach (var nodeId in blueIds.Where(id => !pendingNodes.Contains(id)))
        {
            pendingNodes.Add(nodeId);
        }

        // Sources dropped from an aggregate list are edges that go away.
        foreach (var (aggregatorId, sources) in aggregateEdits)
        {
            var original = nodes.FirstOrDefault(n => n.Id == aggregatorId)?.Aggregate ?? Array.Empty<string>();

            foreach (var droppedSource in original.Where(s => !sources.Contains(s)))
            {
                removed.Add((droppedSource, aggregatorId, "aggregate", false));
            }
        }

        // A removed node's own bindings are edges that go away with it.
        foreach (var removedNode in RemovedNodes)
        {
            foreach (var binding in removedNode.Bindings.Where(b => IsEdgeSource(b.From)))
            {
                removed.Add((binding.From, removedNode.Id, binding.Variable, false));
            }
        }

        return (changed, removed, pendingNodes);
    }

    // item:* sources render inside node labels, not as edges.
    private static bool IsEdgeSource(string from) =>
        from.StartsWith("node:", StringComparison.Ordinal)
        || from.StartsWith("input:", StringComparison.Ordinal)
        || from.StartsWith("data:", StringComparison.Ordinal);

    private static string DecoratePendingDiagram(
        string diagram,
        IReadOnlyList<(string NodeId, string Variable)> changed,
        IReadOnlyList<(string From, string NodeId, string Variable, bool Rebound)> removed,
        IReadOnlyList<string> pendingNodeIds,
        IReadOnlyList<string>? removedNodes = null)
    {
        var sb = new System.Text.StringBuilder(diagram);

        if (!diagram.EndsWith('\n'))
        {
            sb.Append('\n');
        }

        // Mermaid styles edges by document-order index: walk the generator's
        // link lines ({source} -->|"{label}"| {target}), matching changed
        // pairs; a parse miss just skips the edge (node outline still shows).
        var blueIndices = new List<int>();
        var linkIndex = 0;

        foreach (var line in diagram.Split('\n'))
        {
            if (!line.Contains("-->", StringComparison.Ordinal))
            {
                continue;
            }

            var labelStart = line.IndexOf("|\"", StringComparison.Ordinal);
            var labelEnd = labelStart < 0 ? -1 : line.IndexOf("\"|", labelStart + 2, StringComparison.Ordinal);

            if (labelEnd > labelStart)
            {
                var label = line[(labelStart + 2)..labelEnd];
                var target = line[(labelEnd + 2)..].Trim();

                foreach (var (nodeId, variable) in changed)
                {
                    if (target == SanitizeMermaidId(nodeId)
                        && (label == variable || label.StartsWith(variable + " (as ", StringComparison.Ordinal)))
                    {
                        blueIndices.Add(linkIndex);
                        break;
                    }
                }
            }

            linkIndex++;
        }

        // Removed/old edges are appended dashed; their indices continue the
        // link count. A source only those edges reference is absent from the
        // effective text — the appended edge re-creates it, marked red.
        var redIndices = new List<int>();
        var redNodeIds = new List<string>();

        foreach (var (from, nodeId, variable, rebound) in removed)
        {
            var sourceRaw = from.StartsWith("node:", StringComparison.Ordinal) ? from["node:".Length..] : from;
            var sourceId = SanitizeMermaidId(sourceRaw);
            var suffix = rebound ? "(was)" : "(removed)";

            sb.Append($"    {sourceId} -. \"{variable} {suffix}\" .-> {SanitizeMermaidId(nodeId)}\n");
            redIndices.Add(linkIndex++);

            if (!diagram.Contains(sourceId + "(", StringComparison.Ordinal)
                && !diagram.Contains(sourceId + "[", StringComparison.Ordinal)
                && !redNodeIds.Contains(sourceId))
            {
                redNodeIds.Add(sourceId);
            }
        }

        // Whole removed nodes (#117): red whether their box survives in the
        // effective text (a dependent still binds them) or only exists through
        // the appended dashed edges.
        foreach (var removedNodeId in removedNodes ?? Array.Empty<string>())
        {
            var sanitized = SanitizeMermaidId(removedNodeId);

            if (!redNodeIds.Contains(sanitized))
            {
                redNodeIds.Add(sanitized);
            }
        }

        if (pendingNodeIds.Count > 0)
        {
            sb.Append("    classDef pending stroke:#0067b8,stroke-width:2.5px\n");
            sb.Append($"    class {string.Join(",", pendingNodeIds.Select(SanitizeMermaidId))} pending\n");
        }

        if (redNodeIds.Count > 0)
        {
            sb.Append("    classDef removed stroke:#a4262c,color:#a4262c\n");
            sb.Append($"    class {string.Join(",", redNodeIds)} removed\n");
        }

        foreach (var index in blueIndices)
        {
            sb.Append($"    linkStyle {index} stroke:#0067b8,stroke-width:2px\n");
        }

        foreach (var index in redIndices)
        {
            sb.Append($"    linkStyle {index} stroke:#a4262c,stroke-width:2px\n");
        }

        return sb.ToString();
    }

    private static string SanitizeMermaidId(string raw)
        => new(raw.Select(c => char.IsLetterOrDigit(c) ? c : '_').ToArray());

    private WorkflowManifestReader.DataItemView? SelectedStandard() =>
        collections.SelectMany(c => c.Items).FirstOrDefault(item => item.File == selectedKey);

    private WorkflowManifestReader.PromptView? SelectedPrompt() =>
        EffectivePrompts.FirstOrDefault(prompt => prompt.File == selectedKey);

    private string GetText(string path) =>
        AddedNodeForPromptFile(path) is { } addedNode ? addedNode.PromptText
        : AddedPromptForFile(path) is { } addedPrompt ? addedPrompt.Text
        : edits.TryGetValue(path, out var edited) ? edited : content!.Files.GetValueOrDefault(path, string.Empty);

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = null;
        edits.Clear();
        addedItems.Clear();
        addedCollections.Clear();
        removedFiles.Clear();
        bindingEdits.Clear();
        nodeEdits.Clear();
        addedNodes.Clear();
        removedNodeIds.Clear();
        aggregateEdits.Clear();
        resultEdit = null;
        addedPrompts.Clear();
        newPromptId = null;
        newPromptError = null;
        variableAdds.Clear();
        variableRemovals.Clear();
        newVariableName = null;
        newVariableSource = string.Empty;
        newVariableError = null;
        newItemError = null;
        newCollectionId = null;
        newCollectionError = null;
        newNodeId = newNodeLabel = null;
        newNodeForEach = string.Empty;
        newNodeOutput = string.Empty;
        newNodeKind = "prompt";
        newNodeError = null;

        // The diagram belongs to the loaded version: drop it so package
        // switches and post-publish reloads never show a stale graph.
        diagramText = null;
        diagramIncludesPending = false;

        try
        {
            content = await WorkflowService.GetCurrentPackageContentAsync();
            prompts = WorkflowManifestReader.ReadPrompts(content.Manifest);
            nodes = WorkflowManifestReader.ReadNodes(content.Manifest);
            collections = WorkflowManifestReader.ReadCollections(content.Manifest, content.Files);
            scalars = WorkflowManifestReader.ReadScalars(content.Manifest);
            schemaIds = WorkflowManifestReader.ReadSchemaIds(content.Manifest);
            await RestoreDraftAsync();

            // Keep the selection when it still exists in the loaded version;
            // otherwise land on the first standard.
            if (selectedKey != null
                && selectedKey.StartsWith(NodeKeyPrefix, StringComparison.Ordinal)
                && nodes.Any(n => NodeKeyFor(n.Id) == selectedKey))
            {
                // A still-existing node pane survives reloads.
            }
            else if (selectedKey != GraphKey && (selectedKey == null || !content.Files.ContainsKey(selectedKey)))
            {
                selectedKey = collections.SelectMany(c => c.Items).FirstOrDefault()?.File
                    ?? prompts.FirstOrDefault()?.File
                    ?? GraphKey;
            }

            if (selectedKey == GraphKey)
            {
                _ = LoadDiagramAsync();
            }
        }
        catch (AccessTokenNotAvailableException exception)
        {
            exception.Redirect();
        }
        catch (Exception ex)
        {
            content = null;
            loadError = $"Unable to load the workflow package: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private sealed record DraftAdded(string Collection, string Id, string Name, string Content);

    private sealed record DraftBinding(string NodeId, string Variable, string From, string? As);

    private sealed record DraftNodeEdit(string NodeId, string Label, string? ForEach, string? OutputSchema, string? FailIfEmpty, string? Prompt = null);

    private sealed record DraftAddedNode(string Id, string Label, string? ForEach, string? OutputSchema, string? FailIfEmpty, string PromptText, List<string>? Aggregate = null, string? PromptRef = null);

    private sealed record DraftAddedPrompt(string Id, string Text);

    private sealed record DraftPayload(
        int Version,
        Dictionary<string, string>? Edits,
        List<DraftAdded>? Added,
        List<string>? Removed,
        List<DraftBinding>? Bindings = null,
        Dictionary<string, List<string>>? VariableAdds = null,
        Dictionary<string, List<string>>? VariableRemovals = null,
        List<string>? AddedCollections = null,
        List<DraftNodeEdit>? NodeEdits = null,
        List<DraftAddedNode>? AddedNodes = null,
        List<string>? RemovedNodes = null,
        Dictionary<string, List<string>>? AggregateEdits = null,
        string? ResultEdit = null,
        List<DraftAddedPrompt>? AddedPrompts = null);

    private async Task RestoreDraftAsync()
    {
        var stored = await JS.InvokeAsync<string?>("localStorage.getItem", DraftKey);

        if (string.IsNullOrWhiteSpace(stored))
        {
            return;
        }

        Dictionary<string, string>? textEdits = null;
        List<DraftAdded>? added = null;
        List<string>? removed = null;
        List<DraftBinding>? bindings = null;
        Dictionary<string, List<string>>? draftVariableAdds = null;
        Dictionary<string, List<string>>? draftVariableRemovals = null;
        List<string>? draftAddedCollections = null;
        List<DraftNodeEdit>? draftNodeEdits = null;
        List<DraftAddedNode>? draftAddedNodes = null;
        List<string>? draftRemovedNodes = null;
        Dictionary<string, List<string>>? draftAggregateEdits = null;
        string? draftResultEdit = null;
        List<DraftAddedPrompt>? draftAddedPrompts = null;

        try
        {
            // Versioned draft (#115) first; legacy plain-dictionary drafts fall through.
            if (stored.Contains("\"Version\"", StringComparison.OrdinalIgnoreCase) || stored.Contains("\"version\"", StringComparison.OrdinalIgnoreCase))
            {
                var payload = JsonSerializer.Deserialize<DraftPayload>(stored);
                textEdits = payload?.Edits;
                added = payload?.Added;
                removed = payload?.Removed;
                bindings = payload?.Bindings;
                draftVariableAdds = payload?.VariableAdds;
                draftVariableRemovals = payload?.VariableRemovals;
                draftAddedCollections = payload?.AddedCollections;
                draftNodeEdits = payload?.NodeEdits;
                draftAddedNodes = payload?.AddedNodes;
                draftRemovedNodes = payload?.RemovedNodes;
                draftAggregateEdits = payload?.AggregateEdits;
                draftResultEdit = payload?.ResultEdit;
                draftAddedPrompts = payload?.AddedPrompts;
            }
            else
            {
                textEdits = JsonSerializer.Deserialize<Dictionary<string, string>>(stored);
            }
        }
        catch (JsonException)
        {
            return;
        }

        foreach (var (path, text) in textEdits ?? new Dictionary<string, string>())
        {
            // Drop entries that no longer differ (or no longer exist) in the
            // loaded package version.
            if (content!.Files.TryGetValue(path, out var original) && !string.Equals(original, text, StringComparison.Ordinal))
            {
                edits[path] = text;
            }
        }

        // Folders before items: an item in a pending folder is only kept when
        // its folder was restored. A folder whose id now exists in the loaded
        // package (published elsewhere) is dropped.
        foreach (var folderId in draftAddedCollections ?? new List<string>())
        {
            if (CollectionIdPattern.IsMatch(folderId)
                && collections.All(c => c.Id != folderId)
                && !scalars.Contains(folderId, StringComparer.Ordinal)
                && !addedCollections.Contains(folderId))
            {
                addedCollections.Add(folderId);
            }
        }

        var loadedIds = collections.SelectMany(c => c.Items.Select(i => (c.Id, i.Id))).ToHashSet();
        var validCollections = collections.Select(c => c.Id).Concat(addedCollections).ToHashSet(StringComparer.Ordinal);

        foreach (var draftItem in added ?? new List<DraftAdded>())
        {
            if (!string.IsNullOrWhiteSpace(draftItem.Id)
                && validCollections.Contains(draftItem.Collection)
                && !loadedIds.Contains((draftItem.Collection, draftItem.Id)))
            {
                addedItems.Add(new AddedItem { Collection = draftItem.Collection, Id = draftItem.Id, Name = draftItem.Name, Content = draftItem.Content });
            }
        }

        foreach (var path in removed ?? new List<string>())
        {
            if (content!.Files.ContainsKey(path))
            {
                removedFiles.Add(path);
            }
        }

        // Variables before bindings: an added-variable binding is only kept
        // when its declaration was restored.
        foreach (var (promptId, addNames) in draftVariableAdds ?? new Dictionary<string, List<string>>())
        {
            foreach (var addName in addNames ?? new List<string>())
            {
                // TryDeclareVariable revalidates (prompt existence, name shape,
                // uniqueness against the loaded version).
                TryDeclareVariable(promptId, addName, out _);
            }
        }

        foreach (var (promptId, removedNames) in draftVariableRemovals ?? new Dictionary<string, List<string>>())
        {
            var prompt = prompts.FirstOrDefault(p => p.Id == promptId);

            if (prompt == null)
            {
                continue;
            }

            foreach (var removedName in (removedNames ?? new List<string>()).Where(v => prompt.Variables.Contains(v, StringComparer.Ordinal)))
            {
                if (!variableRemovals.TryGetValue(promptId, out var set))
                {
                    variableRemovals[promptId] = set = new HashSet<string>(StringComparer.Ordinal);
                }

                set.Add(removedName);
            }
        }

        // Standalone prompts before nodes (a restored node may point at one),
        // nodes before variables and bindings. Anything whose id now exists in
        // the loaded package is dropped.
        foreach (var draftAddedPrompt in draftAddedPrompts ?? new List<DraftAddedPrompt>())
        {
            if (!string.IsNullOrWhiteSpace(draftAddedPrompt.Id)
                && prompts.All(p => p.Id != draftAddedPrompt.Id)
                && nodes.All(n => n.Id != draftAddedPrompt.Id)
                && addedPrompts.All(p => p.Id != draftAddedPrompt.Id))
            {
                addedPrompts.Add(new AddedPrompt { Id = draftAddedPrompt.Id, Text = draftAddedPrompt.Text });
            }
        }

        foreach (var draftAddedNode in draftAddedNodes ?? new List<DraftAddedNode>())
        {
            if (!string.IsNullOrWhiteSpace(draftAddedNode.Id)
                && !string.IsNullOrWhiteSpace(draftAddedNode.Label)
                && nodes.All(n => n.Id != draftAddedNode.Id)
                && prompts.All(p => p.Id != draftAddedNode.Id)
                && addedNodes.All(a => a.Id != draftAddedNode.Id))
            {
                // A vanished PromptRef target falls back to a fresh prompt
                // named after the node.
                var promptRef = draftAddedNode.PromptRef != null
                    && (prompts.Any(p => p.Id == draftAddedNode.PromptRef) || addedPrompts.Any(p => p.Id == draftAddedNode.PromptRef))
                        ? draftAddedNode.PromptRef
                        : null;

                addedNodes.Add(new AddedNode
                {
                    Id = draftAddedNode.Id,
                    Label = draftAddedNode.Label,
                    ForEach = draftAddedNode.ForEach,
                    OutputSchema = draftAddedNode.OutputSchema,
                    FailIfEmpty = draftAddedNode.FailIfEmpty,
                    PromptText = draftAddedNode.PromptText,
                    Aggregate = draftAddedNode.Aggregate,
                    PromptRef = promptRef
                });
            }
        }

        foreach (var removedNodeId in draftRemovedNodes ?? new List<string>())
        {
            if (nodes.Any(n => n.Id == removedNodeId && !n.IsResult))
            {
                removedNodeIds.Add(removedNodeId);
            }
        }

        // Aggregate-list edits: kept when the aggregator still exists and the
        // list still differs; the deliverable selection when it still differs
        // and its target still exists.
        foreach (var (aggregatorId, sources) in draftAggregateEdits ?? new Dictionary<string, List<string>>())
        {
            var original = nodes.FirstOrDefault(n => n.Id == aggregatorId)?.Aggregate;

            if (original != null && sources is { Count: > 0 }
                && !original.SequenceEqual(sources, StringComparer.Ordinal))
            {
                aggregateEdits[aggregatorId] = sources;
            }
        }

        if (draftResultEdit != null
            && draftResultEdit != WorkflowManifestReader.ReadResultRef(content!.Manifest)
            && draftResultEdit.StartsWith("node:", StringComparison.Ordinal)
            && EffectiveNodes.Any(n => n.Id == draftResultEdit["node:".Length..]))
        {
            resultEdit = draftResultEdit;
        }

        // Node-field edits: kept only when the node still exists and the
        // tuple still differs from the loaded version.
        foreach (var draftNodeEdit in draftNodeEdits ?? new List<DraftNodeEdit>())
        {
            var original = nodes.FirstOrDefault(n => n.Id == draftNodeEdit.NodeId);

            if (original == null
                || string.IsNullOrWhiteSpace(draftNodeEdit.Label)
                || (draftNodeEdit.Label == original.Label
                    && draftNodeEdit.ForEach == original.ForEach
                    && draftNodeEdit.OutputSchema == original.OutputSchema
                    && draftNodeEdit.FailIfEmpty == original.FailIfEmpty
                    && (draftNodeEdit.Prompt == null || draftNodeEdit.Prompt == original.Prompt)))
            {
                continue;
            }

            nodeEdits[draftNodeEdit.NodeId] = new WorkflowNodeSummary.NodeChange(
                draftNodeEdit.NodeId, draftNodeEdit.Label, draftNodeEdit.ForEach, draftNodeEdit.OutputSchema, draftNodeEdit.FailIfEmpty, draftNodeEdit.Prompt);
        }

        foreach (var draftBinding in bindings ?? new List<DraftBinding>())
        {
            // Keep rebinds whose node/variable still exists and still differs —
            // or which bind a restored added variable (no original to differ
            // from; effective nodes cover restored pending nodes too).
            var node = EffectiveNodes.FirstOrDefault(n => n.Id == draftBinding.NodeId);
            var original = node?.Bindings.FirstOrDefault(b => b.Variable == draftBinding.Variable);

            if (original != null && (original.From != draftBinding.From || original.As != draftBinding.As))
            {
                bindingEdits[BindingKey(draftBinding.NodeId, draftBinding.Variable)] = (draftBinding.From, draftBinding.As);
            }
            else if (original == null
                && node != null
                && AddedVariables(node.Prompt).Contains(draftBinding.Variable, StringComparer.Ordinal))
            {
                bindingEdits[BindingKey(draftBinding.NodeId, draftBinding.Variable)] = (draftBinding.From, draftBinding.As);
            }
        }
    }

    private async Task PersistDraftAsync()
    {
        if (PendingCount == 0)
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", DraftKey);
            return;
        }

        var payload = new DraftPayload(
            9,
            edits,
            addedItems.Select(a => new DraftAdded(a.Collection, a.Id, a.Name, a.Content)).ToList(),
            removedFiles.ToList(),
            bindingEdits.Select(pair =>
            {
                var parts = pair.Key.Split('\n', 2);
                return new DraftBinding(parts[0], parts[1], pair.Value.From, pair.Value.As);
            }).ToList(),
            variableAdds.ToDictionary(pair => pair.Key, pair => pair.Value.ToList()),
            variableRemovals.ToDictionary(pair => pair.Key, pair => pair.Value.ToList()),
            addedCollections.ToList(),
            nodeEdits.Values.Select(edit => new DraftNodeEdit(edit.NodeId, edit.Label, edit.ForEach, edit.OutputSchema, edit.FailIfEmpty, edit.Prompt)).ToList(),
            addedNodes.Select(a => new DraftAddedNode(a.Id, a.Label, a.ForEach, a.OutputSchema, a.FailIfEmpty, a.PromptText, a.Aggregate, a.PromptRef)).ToList(),
            removedNodeIds.ToList(),
            aggregateEdits.ToDictionary(pair => pair.Key, pair => pair.Value.ToList()),
            resultEdit,
            addedPrompts.Select(p => new DraftAddedPrompt(p.Id, p.Text)).ToList());
        await JS.InvokeVoidAsync("localStorage.setItem", DraftKey, JsonSerializer.Serialize(payload));
    }

    private async Task OnTextChangedAsync(string path, string value)
    {
        publishSuccess = null;

        // A pending node's or standalone pending prompt's text lives on its
        // draft object, not in edits.
        if (AddedNodeForPromptFile(path) is { } addedNode)
        {
            addedNode.PromptText = value;
            await PersistDraftAsync();
            return;
        }

        if (AddedPromptForFile(path) is { } addedPrompt)
        {
            addedPrompt.Text = value;
            await PersistDraftAsync();
            return;
        }

        if (content!.Files.TryGetValue(path, out var original) && string.Equals(original, value, StringComparison.Ordinal))
        {
            edits.Remove(path);
        }
        else
        {
            edits[path] = value;
        }

        await PersistDraftAsync();
    }

    private bool CollectionHasMembershipChanges(WorkflowManifestReader.CollectionView collection) =>
        collection.Items.Any(item => removedFiles.Contains(item.File))
        || addedItems.Any(a => a.Collection == collection.Id);

    private string ComposeIndexJson(WorkflowManifestReader.CollectionView collection)
    {
        // Preserve the loaded field list (new folders have none — the default
        // applies); existing items keep their order, removals drop, additions
        // append.
        var fields = new List<string> { "id", "name", "content" };
        if (content!.Files.TryGetValue(collection.Directory + "index.json", out var loadedIndexJson))
        {
            try
            {
                using var loadedIndex = System.Text.Json.JsonDocument.Parse(loadedIndexJson);
                if (loadedIndex.RootElement.TryGetProperty("fields", out var f) && f.ValueKind == JsonValueKind.Array)
                {
                    fields = f.EnumerateArray().Select(v => v.GetString() ?? string.Empty).ToList();
                }
            }
            catch (JsonException)
            {
            }
        }

        var items = collection.Items
            .Where(item => !removedFiles.Contains(item.File))
            .Select(item => new { id = item.Id, name = item.Name, file = item.File[collection.Directory.Length..] })
            .Concat(addedItems
                .Where(a => a.Collection == collection.Id)
                .Select(a => new { id = a.Id, name = a.Name, file = $"{a.Id}.md" }))
            .ToList();

        return JsonSerializer.Serialize(new { fields, items }, new JsonSerializerOptions { WriteIndented = true });
    }

    private async Task PublishAsync()
    {
        if (content == null || PendingCount == 0 || isPublishing)
        {
            return;
        }

        isPublishing = true;
        publishErrors = new List<string>();
        publishSuccess = null;

        try
        {
            // Declared-but-unbound variables and empty new folders block publish
            // with a named message (explicit initialization; the validator would
            // reject both anyway — this is just the friendlier failure).
            var unbound = new List<string>();

            foreach (var folderId in addedCollections)
            {
                if (!addedItems.Any(a => a.Collection == folderId))
                {
                    unbound.Add($"Data folder '{folderId}' has no items yet — add at least one before publishing.");
                }
            }

            foreach (var addedNode in addedNodes)
            {
                if (addedNode.Aggregate != null)
                {
                    if (addedNode.Aggregate.Count == 0)
                    {
                        unbound.Add($"Aggregator '{addedNode.Id}' has no sources yet — add at least one on its card.");
                    }
                }
                else if (addedNode.PromptRef == null && string.IsNullOrWhiteSpace(addedNode.PromptText))
                {
                    unbound.Add($"Node '{addedNode.Id}' has no prompt text yet — write it under Prompts.");
                }
            }

            // Standalone pending prompts: text required, and the orphan rule's
            // friendly face — some node must use them.
            foreach (var pending in addedPrompts)
            {
                if (string.IsNullOrWhiteSpace(pending.Text))
                {
                    unbound.Add($"Prompt '{pending.Id}' has no text yet — write it under Prompts.");
                }
                else if (!EffectiveNodes.Any(n => n.Prompt == pending.Id))
                {
                    unbound.Add($"Prompt '{pending.Id}' is not used by any node yet — point a node at it or remove it.");
                }
            }

            // Re-pointed nodes and nodes born onto an existing prompt: every
            // variable of that prompt needs an explicitly chosen source.
            foreach (var node in EffectiveNodes.Where(HasFreshBindings))
            {
                var freshPrompt = EffectivePrompts.FirstOrDefault(p => p.Id == node.Prompt);

                foreach (var variable in freshPrompt != null ? EffectiveVariables(freshPrompt) : Array.Empty<string>())
                {
                    if (string.IsNullOrEmpty(GetEffectiveBinding(node.Id, variable)?.From))
                    {
                        unbound.Add($"Variable '{variable}' on node '{node.Id}' needs a source — set it in Graph.");
                    }
                }
            }

            foreach (var prompt in EffectivePrompts)
            {
                foreach (var variable in AddedVariables(prompt.Id))
                {
                    foreach (var node in NodesUsingPrompt(prompt.Id))
                    {
                        if (string.IsNullOrEmpty(GetEffectiveBinding(node.Id, variable)?.From))
                        {
                            unbound.Add($"Variable '{variable}' on node '{node.Id}' needs a source — set it in Graph.");
                        }
                    }
                }
            }

            if (unbound.Count > 0)
            {
                publishErrors = unbound;
                return;
            }

            var files = new Dictionary<string, string>(content.Files, StringComparer.Ordinal);
            foreach (var (path, text) in edits)
            {
                files[path] = text;
            }

            foreach (var path in removedFiles)
            {
                files.Remove(path);
            }

            foreach (var added in addedItems)
            {
                files[AddedPath(added)] = added.Content;
            }

            // Pending fresh prompts and standalone pending prompts bring their
            // files; a removed node takes its prompt's file away only when no
            // other effective node still uses the prompt.
            foreach (var addedNode in addedNodes.Where(a => a.Aggregate == null && a.PromptRef == null))
            {
                files[AddedPromptFile(addedNode.Id)] = addedNode.PromptText;
            }

            foreach (var pending in addedPrompts)
            {
                files[AddedStandalonePromptFile(pending.Id)] = pending.Text;
            }

            foreach (var removedNodeId in removedNodeIds)
            {
                var promptId = nodes.FirstOrDefault(n => n.Id == removedNodeId)?.Prompt;
                var promptFile = promptId != null ? prompts.FirstOrDefault(p => p.Id == promptId)?.File : null;

                if (promptFile != null && !EffectiveNodes.Any(n => n.Prompt == promptId))
                {
                    files.Remove(promptFile);
                }
            }

            // Membership changed => the collection's index.json is recomposed
            // (new folders always compose theirs); the server validator remains
            // the authority on the result.
            foreach (var collection in EffectiveCollections)
            {
                if (CollectionHasMembershipChanges(collection) || addedCollections.Contains(collection.Id))
                {
                    files[collection.Directory + "index.json"] = ComposeIndexJson(collection);
                }
            }

            var outcome = await WorkflowService.PublishPackageAsync(
                new WorkflowPackagePublishRequest(content.Ref, ComposeManifest(), files));

            if (!outcome.Succeeded)
            {
                publishErrors = outcome.Errors.ToList();
                return;
            }

            await JS.InvokeVoidAsync("localStorage.removeItem", DraftKey);
            var publishedRef = outcome.Response!.Ref;
            await LoadAsync();
            publishSuccess = $"Published {publishedRef} and switched your consults to it.";
        }
        catch (AccessTokenNotAvailableException exception)
        {
            exception.Redirect();
        }
        catch (Exception ex)
        {
            publishErrors = new List<string> { $"Publish failed: {ex.Message}" };
        }
        finally
        {
            isPublishing = false;
        }
    }

    private async Task DiscardAsync()
    {
        if (content == null)
        {
            return;
        }

        edits.Clear();
        addedItems.Clear();
        addedCollections.Clear();
        removedFiles.Clear();
        bindingEdits.Clear();
        nodeEdits.Clear();
        addedNodes.Clear();
        removedNodeIds.Clear();
        aggregateEdits.Clear();
        resultEdit = null;
        addedPrompts.Clear();
        newPromptId = null;
        newPromptError = null;
        variableAdds.Clear();
        variableRemovals.Clear();
        newVariableName = null;
        newVariableSource = string.Empty;
        newVariableError = null;
        newItemId = newItemName = newItemContent = null;
        newItemError = null;
        newCollectionId = null;
        newCollectionError = null;
        newNodeId = newNodeLabel = null;
        newNodeForEach = string.Empty;
        newNodeOutput = string.Empty;
        newNodeKind = "prompt";
        newNodeError = null;
        publishErrors = new List<string>();
        publishSuccess = null;
        await JS.InvokeVoidAsync("localStorage.removeItem", DraftKey);
    }

    // The manifest rides opaque except for this one surgical write: pending
    // rebinds land in nodes[].bindings, everything else passes through. Casing
    // is tolerant like the reader's — the worker serializer may have written
    // PascalCase, and the server parses either. Binding dictionary keys
    // (variable names) are never re-cased by the serializer.
    private JsonElement ComposeManifest()
    {
        if (bindingEdits.Count == 0 && VariableAddCount == 0 && VariableRemovalCount == 0
            && addedCollections.Count == 0 && nodeEdits.Count == 0
            && addedNodes.Count == 0 && removedNodeIds.Count == 0 && addedPrompts.Count == 0
            && aggregateEdits.Count == 0 && resultEdit == null)
        {
            return content!.Manifest;
        }

        var root = System.Text.Json.Nodes.JsonNode.Parse(content!.Manifest.GetRawText())!;

        // New folders (#154): one data-map entry per pending collection; the
        // directory value's trailing slash is what marks it as a collection.
        if (addedCollections.Count > 0)
        {
            var dataKey = root["Data"] is not null ? "Data" : "data";
            if (root[dataKey] is not System.Text.Json.Nodes.JsonObject dataObject)
            {
                dataObject = new System.Text.Json.Nodes.JsonObject();
                root[dataKey] = dataObject;
            }

            foreach (var folderId in addedCollections)
            {
                dataObject[folderId] = $"data/{folderId}/";
            }
        }

        // Variable declarations: each edited prompt's variables array becomes
        // the effective set (declared order minus removals, adds appended).
        if ((root["prompts"] ?? root["Prompts"]) is System.Text.Json.Nodes.JsonArray promptsArray)
        {
            foreach (var prompt in prompts)
            {
                if (!HasVariableEdits(prompt.Id))
                {
                    continue;
                }

                var promptObject = promptsArray
                    .OfType<System.Text.Json.Nodes.JsonObject>()
                    .FirstOrDefault(p => (p["id"] ?? p["Id"])?.GetValue<string>() == prompt.Id);

                if (promptObject == null)
                {
                    continue;
                }

                var variablesKey = promptObject.ContainsKey("Variables") ? "Variables" : "variables";
                promptObject[variablesKey] = new System.Text.Json.Nodes.JsonArray(
                    EffectiveVariables(prompt)
                        .Select(v => (System.Text.Json.Nodes.JsonNode?)System.Text.Json.Nodes.JsonValue.Create(v))
                        .ToArray());
            }
        }

        if ((root["nodes"] ?? root["Nodes"]) is not System.Text.Json.Nodes.JsonArray nodesArray)
        {
            return JsonSerializer.SerializeToElement(root);
        }

        System.Text.Json.Nodes.JsonObject? NodeFor(string nodeId) =>
            nodesArray
                .OfType<System.Text.Json.Nodes.JsonObject>()
                .FirstOrDefault(n => (n["id"] ?? n["Id"])?.GetValue<string>() == nodeId);

        System.Text.Json.Nodes.JsonObject? BindingsFor(string nodeId) =>
            NodeFor(nodeId) is { } nodeObject
                && (nodeObject["bindings"] ?? nodeObject["Bindings"]) is System.Text.Json.Nodes.JsonObject bindingsObject
                    ? bindingsObject
                    : null;

        // Pending new nodes (#117): the node object and — for prompt nodes —
        // its 1:1 prompt entry. Bindings start empty here; the generic rebind
        // loop below fills them from bindingEdits like any other node's.
        // Aggregators carry only their ordered source list.
        foreach (var addedNode in addedNodes)
        {
            if (addedNode.Aggregate != null)
            {
                nodesArray.Add(new System.Text.Json.Nodes.JsonObject
                {
                    ["id"] = addedNode.Id,
                    ["label"] = addedNode.Label,
                    ["aggregate"] = new System.Text.Json.Nodes.JsonArray(
                        addedNode.Aggregate
                            .Select(s => (System.Text.Json.Nodes.JsonNode?)System.Text.Json.Nodes.JsonValue.Create(s))
                            .ToArray())
                });
                continue;
            }

            if (addedNode.PromptRef == null
                && (root["prompts"] ?? root["Prompts"]) is System.Text.Json.Nodes.JsonArray promptsArrayForAdd)
            {
                promptsArrayForAdd.Add(new System.Text.Json.Nodes.JsonObject
                {
                    ["id"] = addedNode.Id,
                    ["file"] = AddedPromptFile(addedNode.Id),
                    ["variables"] = new System.Text.Json.Nodes.JsonArray(
                        AddedVariables(addedNode.Id)
                            .Select(v => (System.Text.Json.Nodes.JsonNode?)System.Text.Json.Nodes.JsonValue.Create(v))
                            .ToArray())
                });
            }

            var newNodeObject = new System.Text.Json.Nodes.JsonObject
            {
                ["id"] = addedNode.Id,
                ["label"] = addedNode.Label,
                ["prompt"] = addedNode.PromptRef ?? addedNode.Id,
                ["bindings"] = new System.Text.Json.Nodes.JsonObject()
            };

            if (addedNode.ForEach != null)
            {
                newNodeObject["forEach"] = addedNode.ForEach;
            }

            if (addedNode.OutputSchema != null)
            {
                var newOutputObject = new System.Text.Json.Nodes.JsonObject { ["schema"] = addedNode.OutputSchema };

                if (!string.IsNullOrWhiteSpace(addedNode.FailIfEmpty))
                {
                    newOutputObject["failIfEmpty"] = addedNode.FailIfEmpty;
                }

                newNodeObject["output"] = newOutputObject;
            }

            nodesArray.Add(newNodeObject);
        }

        // Aggregate-list edits on existing aggregators (#117).
        foreach (var pair in aggregateEdits)
        {
            if (!removedNodeIds.Contains(pair.Key) && NodeFor(pair.Key) is { } aggregatorObject)
            {
                aggregatorObject[aggregatorObject.ContainsKey("Aggregate") ? "Aggregate" : "aggregate"] =
                    new System.Text.Json.Nodes.JsonArray(
                        pair.Value
                            .Select(s => (System.Text.Json.Nodes.JsonNode?)System.Text.Json.Nodes.JsonValue.Create(s))
                            .ToArray());
            }
        }

        // The pending deliverable selection.
        if (resultEdit != null)
        {
            root[root["Result"] is not null ? "Result" : "result"] = resultEdit;
        }

        // Removed nodes lose their node object and their prompt entry.
        foreach (var removedNodeId in removedNodeIds)
        {
            if (NodeFor(removedNodeId) is { } removedNodeObject)
            {
                nodesArray.Remove(removedNodeObject);
            }

            var removedPromptId = nodes.FirstOrDefault(n => n.Id == removedNodeId)?.Prompt;

            if (removedPromptId != null
                && !EffectiveNodes.Any(n => n.Prompt == removedPromptId)
                && (root["prompts"] ?? root["Prompts"]) is System.Text.Json.Nodes.JsonArray promptsArrayForRemove
                && promptsArrayForRemove
                    .OfType<System.Text.Json.Nodes.JsonObject>()
                    .FirstOrDefault(p => (p["id"] ?? p["Id"])?.GetValue<string>() == removedPromptId) is { } removedPromptObject)
            {
                promptsArrayForRemove.Remove(removedPromptObject);
            }
        }

        // Standalone pending prompts (#170): one prompts[] entry each.
        if (addedPrompts.Count > 0
            && (root["prompts"] ?? root["Prompts"]) is System.Text.Json.Nodes.JsonArray promptsArrayForStandalone)
        {
            foreach (var pending in addedPrompts)
            {
                promptsArrayForStandalone.Add(new System.Text.Json.Nodes.JsonObject
                {
                    ["id"] = pending.Id,
                    ["file"] = AddedStandalonePromptFile(pending.Id),
                    ["variables"] = new System.Text.Json.Nodes.JsonArray(
                        AddedVariables(pending.Id)
                            .Select(v => (System.Text.Json.Nodes.JsonNode?)System.Text.Json.Nodes.JsonValue.Create(v))
                            .ToArray())
                });
            }
        }

        // Node-field edits (#117): label always written; forEach and output
        // written or removed to match the effective tuple. Removed nodes'
        // stale edits are skipped.
        foreach (var pair in nodeEdits)
        {
            if (removedNodeIds.Contains(pair.Key) || NodeFor(pair.Key) is not { } nodeObject)
            {
                continue;
            }

            nodeObject[nodeObject.ContainsKey("Label") ? "Label" : "label"] = pair.Value.Label;

            // A re-pointed prompt replaces the bindings wholesale — the old
            // ones were written for the old prompt's variables; the rebind
            // loop below fills the fresh ones from bindingEdits.
            if (pair.Value.Prompt != null
                && pair.Value.Prompt != nodes.FirstOrDefault(n => n.Id == pair.Key)?.Prompt)
            {
                nodeObject[nodeObject.ContainsKey("Prompt") ? "Prompt" : "prompt"] = pair.Value.Prompt;
                nodeObject.Remove("bindings");
                nodeObject.Remove("Bindings");
                nodeObject["bindings"] = new System.Text.Json.Nodes.JsonObject();
            }

            if (pair.Value.ForEach is null)
            {
                nodeObject.Remove("forEach");
                nodeObject.Remove("ForEach");
            }
            else
            {
                nodeObject[nodeObject.ContainsKey("ForEach") ? "ForEach" : "forEach"] = pair.Value.ForEach;
            }

            if (pair.Value.OutputSchema is null)
            {
                nodeObject.Remove("output");
                nodeObject.Remove("Output");
            }
            else
            {
                var outputObject = new System.Text.Json.Nodes.JsonObject { ["schema"] = pair.Value.OutputSchema };

                if (!string.IsNullOrWhiteSpace(pair.Value.FailIfEmpty))
                {
                    outputObject["failIfEmpty"] = pair.Value.FailIfEmpty;
                }

                nodeObject[nodeObject.ContainsKey("Output") ? "Output" : "output"] = outputObject;
            }
        }

        // Rebinds and added-variable bindings (the indexer adds missing keys).
        foreach (var pair in bindingEdits)
        {
            var parts = pair.Key.Split('\n', 2);

            if (BindingsFor(parts[0]) is not { } bindingsObject)
            {
                continue;
            }

            bindingsObject[parts[1]] = pair.Value.As is null
                ? System.Text.Json.Nodes.JsonValue.Create(pair.Value.From)
                : new System.Text.Json.Nodes.JsonObject
                {
                    ["from"] = pair.Value.From,
                    ["as"] = pair.Value.As
                };
        }

        // Removed variables lose their binding keys on every using node.
        foreach (var prompt in prompts)
        {
            if (!variableRemovals.TryGetValue(prompt.Id, out var removedVariables) || removedVariables.Count == 0)
            {
                continue;
            }

            foreach (var node in NodesUsingPrompt(prompt.Id))
            {
                if (BindingsFor(node.Id) is not { } bindingsObject)
                {
                    continue;
                }

                foreach (var variable in removedVariables)
                {
                    bindingsObject.Remove(variable);
                }
            }
        }

        return JsonSerializer.SerializeToElement(root);
    }

    // A new pin resolves to a different package; drafts are keyed per ref, so
    // pending edits stay with their package and reappear on switching back.
    private async Task OnPackagePinnedAsync()
    {
        await LoadAsync();
    }

    private async Task RevertToDefaultAsync()
    {
        if (isPublishing)
        {
            return;
        }

        publishErrors = new List<string>();
        publishSuccess = null;

        try
        {
            await AccountService.DeleteSettingAsync("consult.workflowPackage");
            await LoadAsync();
            publishSuccess = $"Reverted to the default package ({content?.Ref}). Your published versions are kept.";
        }
        catch (AccessTokenNotAvailableException exception)
        {
            exception.Redirect();
        }
        catch (Exception ex)
        {
            publishErrors = new List<string> { $"Revert failed: {ex.Message}" };
        }
    }
}
