            incoming[node.Id] = sources;
        }

        var resultId = resultRef["node:".Length..];
        var reached = new HashSet<string>(StringComparer.Ordinal);
        var queue = new Queue<string>();

        if (byId.ContainsKey(resultId))
        {
            reached.Add(resultId);
            queue.Enqueue(resultId);
