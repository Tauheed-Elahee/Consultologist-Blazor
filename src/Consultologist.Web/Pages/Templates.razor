@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using System.Net
@using System.Text
@inject IWorkflowEndpointService WorkflowService
@attribute [Authorize]

@page "/templates"

<PageTitle>Templates</PageTitle>

<section class="page-header">
    <div class="page-header__content">
        <span class="section-eyebrow">Templates</span>
        <h1 class="page-title">Section standards for consult notes.</h1>
        <p class="page-description">
            The clinical writing standards used for each generated section, as shipped by the active workflow package.
        </p>
    </div>
</section>

<AuthorizeView>
    <Authorized>
        <section class="content-card">
            <div class="form-stack">
                <div class="result-header">
                    <div>
                        <h2 class="panel-title">Active standards</h2>
                        <p class="panel-description">
                            Standards guide organization and tone only. Patient facts still come from the draft consult.
                        </p>
                    </div>
                </div>

                <FluentMessageBar Intent="MessageIntent.Info" AllowDismiss="false">
                    Standards customization is moving to the workflow package editor, where edits publish
                    as your own package version with full provenance. Until it ships, standards are
                    read-only here. Previously saved custom standards are preserved on your account and
                    will seed your first customized package.
                </FluentMessageBar>

                @if (isLoading)
                {
                    <div class="loading-state">
                        <FluentProgressRing />
                        <span>Loading section standards...</span>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(loadError))
                {
                    <FluentMessageBar Intent="MessageIntent.Error">@loadError</FluentMessageBar>
                }

                @foreach (var standard in standards)
                {
                    <article class="template-section">
                        <div class="template-section__header">
                            <div>
                                <h3 class="panel-title">@standard.Name</h3>
                                <p class="muted-text">@standard.Id</p>
                            </div>
                        </div>

                        <div class="markdown-preview">
                            @((MarkupString)RenderMarkdownPreview(standard.Content))
                        </div>
                    </article>
                }
            </div>
        </section>
    </Authorized>
</AuthorizeView>

@code {
  private IReadOnlyList<WorkflowPackageSectionResponse> standards = Array.Empty<WorkflowPackageSectionResponse>();
  private bool isLoading;
  private string? loadError;

  protected override async Task OnInitializedAsync()
  {
    await LoadStandardsAsync();
  }

  private async Task LoadStandardsAsync()
  {
    isLoading = true;
    loadError = null;

    try
    {
      // The package endpoint is the single section source (the account standards
      // override retired with the v5 input model; customization returns as package
      // forking in the in-app editor).
      var package = await WorkflowService.GetCurrentPackageAsync();
      standards = package.Sections ?? Array.Empty<WorkflowPackageSectionResponse>();
    }
    catch (AccessTokenNotAvailableException exception)
    {
      exception.Redirect();
    }
    catch (Exception ex)
    {
      standards = Array.Empty<WorkflowPackageSectionResponse>();
      loadError = $"Unable to load section standards: {ex.Message}";
    }
    finally
    {
      isLoading = false;
    }
  }

  private static string RenderMarkdownPreview(string markdown)
  {
    if (string.IsNullOrWhiteSpace(markdown))
    {
      return "<p class=\"muted-text\">No standard text.</p>";
    }

    var builder = new StringBuilder();
    var lines = markdown.Replace("\r\n", "\n").Split('\n');
    var inList = false;

    foreach (var rawLine in lines)
    {
      var line = rawLine.Trim();

      if (string.IsNullOrEmpty(line))
      {
        if (inList)
        {
          builder.AppendLine("</ul>");
          inList = false;
        }

        continue;
      }

      if (line.StartsWith("- ", StringComparison.Ordinal))
      {
        if (!inList)
        {
          builder.AppendLine("<ul>");
          inList = true;
        }

        builder.Append("<li>");
        builder.Append(WebUtility.HtmlEncode(line[2..]));
        builder.AppendLine("</li>");
        continue;
      }

      if (inList)
      {
        builder.AppendLine("</ul>");
        inList = false;
      }

      if (line.StartsWith("### ", StringComparison.Ordinal))
      {
        builder.Append("<h4>");
        builder.Append(WebUtility.HtmlEncode(line[4..]));
        builder.AppendLine("</h4>");
      }
      else
      {
        builder.Append("<p>");
        builder.Append(WebUtility.HtmlEncode(line));
        builder.AppendLine("</p>");
      }
    }

    if (inList)
    {
      builder.AppendLine("</ul>");
    }

    return builder.ToString();
  }
}
