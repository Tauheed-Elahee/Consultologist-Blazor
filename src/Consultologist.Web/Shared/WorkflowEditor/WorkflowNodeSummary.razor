@* The node cards, shared by the Graph pane (all nodes) and the sidebar's
   single-node panes (Only set). Read-only by default; with Editable set, the
   node's own fields (label, forEach, output contract, failIfEmpty) become
   inputs (#117), each binding row becomes a source dropdown (+ renderer for
   node sources, #138), rows come from the host's effective model (declared +
   pending-added variables, #140), and each card offers a "+ variable" form.
   The server validator remains the authority on publish. *@
@using Consultologist.Web.Services.Workflow

@foreach (var node in (Only == null ? Nodes : Nodes.Where(n => n.Id == Only)))
{
    <article class="template-section">
        <div class="template-section__header">
            <div>
                <h3 class="panel-title">
                    @node.Label
                    @if (node.IsResult)
                    {
                        <span class="muted-text"> — deliverable</span>
                    }
                </h3>
                <p class="muted-text">
                    @node.Id
                    @if (node.Prompt != null)
                    {
                        <span> · prompt: @node.Prompt</span>
                    }
                    @if (node.ForEach != null)
                    {
                        <span> · for each @node.ForEach item</span>
                    }
                    @if (node.Aggregate != null)
                    {
                        <span> · aggregator</span>
                    }
                    @if (NodeModified?.Invoke(node.Id) == true)
                    {
                        <span class="binding-row__pending" title="Pending change"> ●</span>
                    }
                </p>
            </div>
            @if (Editable && !node.IsResult && OnNodeRemoved.HasDelegate)
            {
                <button type="button" class="add-variable__submit" @onclick="() => OnNodeRemoved.InvokeAsync(node.Id)">
                    Remove node
                </button>
            }
        </div>
        @if (Editable)
        {
            <div class="node-fields">
                <label class="node-field">
                    <span>label</span>
                    <input class="binding-row__select node-field__input"
                           value="@node.Label"
                           @onchange="args => EmitNodeChangeAsync(node, label: args.Value?.ToString() ?? string.Empty)"
                           aria-label="Node label" />
                </label>
                @if (node.Aggregate == null)
                {
                    <label class="node-field">
                        <span>for each</span>
                        <select class="binding-row__select"
                                value="@(node.ForEach ?? string.Empty)"
                                @onchange="args => EmitNodeChangeAsync(node, forEach: args.Value?.ToString())"
                                aria-label="Node forEach collection">
                            <option value="">— runs once —</option>
                            @if (node.ForEach != null && !Collections.Contains(ForEachCollectionId(node.ForEach)))
                            {
                                <option value="@node.ForEach">@node.ForEach</option>
                            }
                            @foreach (var collectionId in Collections)
                            {
                                <option value="@($"data:{collectionId}")">data:@collectionId</option>
                            }
                        </select>
                    </label>
                    <label class="node-field">
                        <span>output</span>
                        <select class="binding-row__select"
                                value="@(node.OutputSchema ?? string.Empty)"
                                @onchange="args => EmitNodeChangeAsync(node, outputSchema: args.Value?.ToString())"
                                aria-label="Node output contract">
                            <option value="">prose (text)</option>
                            @if (node.OutputSchema != null && !ContractOptions.Contains(node.OutputSchema))
                            {
                                <option value="@node.OutputSchema">@node.OutputSchema</option>
                            }
                            @foreach (var contract in ContractOptions)
                            {
                                <option value="@contract">@contract</option>
                            }
                        </select>
                    </label>
                    @if (node.OutputSchema != null)
                    {
                        <label class="node-field node-field--wide">
                            <span>fail if empty</span>
                            <input class="binding-row__select node-field__input"
                                   value="@(node.FailIfEmpty ?? string.Empty)"
                                   placeholder="optional — error shown when the output is empty"
                                   @onchange="args => EmitNodeChangeAsync(node, failIfEmpty: args.Value?.ToString())"
                                   aria-label="Node fail-if-empty message" />
                        </label>
                    }
                }
            </div>
        }
        @if (node.Aggregate != null)
        {
            @* Deterministic aggregation: sources in declared order (v6) — the
               order is the assembled document's order. *@
            @if (Editable && OnAggregateChanged.HasDelegate)
            {
                <ul class="binding-list">
                    @for (var i = 0; i < node.Aggregate.Count; i++)
                    {
                        var index = i;
                        var currentNode = node;
                        <li class="binding-row">
                            <span class="muted-text">@(index + 1).</span>
                            <code>@node.Aggregate[index]</code>
                            <button type="button" class="aggregate-row__button" title="Move up"
                                    disabled="@(index == 0)"
                                    @onclick="() => MoveAggregateSourceAsync(currentNode, index, -1)">↑</button>
                            <button type="button" class="aggregate-row__button" title="Move down"
                                    disabled="@(index == node.Aggregate.Count - 1)"
                                    @onclick="() => MoveAggregateSourceAsync(currentNode, index, +1)">↓</button>
                            <button type="button" class="aggregate-row__button" title="Remove source"
                                    disabled="@(node.Aggregate.Count == 1)"
                                    @onclick="() => RemoveAggregateSourceAsync(currentNode, index)">×</button>
                        </li>
                    }
                </ul>
                <div class="add-variable__form">
                    <select class="binding-row__select"
                            value=""
                            @onchange="args => AppendAggregateSourceAsync(node, args.Value?.ToString())"
                            aria-label="Add aggregate source">
                        <option value="">+ add source…</option>
                        @foreach (var candidate in Nodes.Where(other => other.Id != node.Id && !node.Aggregate.Contains($"node:{other.Id}")))
                        {
                            <option value="@($"node:{candidate.Id}")">node:@candidate.Id</option>
                        }
                    </select>
                </div>
            }
            else
            {
                <ul class="binding-list">
                    @foreach (var sourceRef in node.Aggregate)
                    {
                        <li class="binding-row muted-text">
                            <code>@sourceRef</code>
                            <span aria-hidden="true">→</span>
                            <span>collected in order</span>
                        </li>
                    }
                </ul>
            }
        }
        else
        {
        <ul class="binding-list">
            @foreach (var row in Rows(node))
            {
                var modified = row.IsNew || row.From != row.OriginalFrom || row.As != row.OriginalAs;

                <li class="binding-row @(Editable ? null : "muted-text")">
                    <code class="binding-row__variable">@row.Variable</code>
                    <span aria-hidden="true">←</span>
                    @if (Editable)
                    {
                        <BindingSourceEditor Node="@node"
                                             Row="@row"
                                             Nodes="@Nodes"
                                             Scalars="@Scalars"
                                             OnChanged="@OnBindingChanged" />
                        @if (modified)
                        {
                            <span class="binding-row__pending" title="Pending change">●</span>
                        }
                        @if (row.IsNew && row.From.Length == 0)
                        {
                            <span class="muted-text binding-row__hint">new — choose source</span>
                        }
                    }
                    else
                    {
                        <code>@(row.As is null ? row.From : $"{row.From} (as {row.As})")</code>
                    }
                </li>
            }
        </ul>
        }
        @if (Editable && node.Prompt != null && OnVariableAdded.HasDelegate)
        {
            var form = FormFor(node.Id);
            <details class="add-variable">
                <summary>+ variable</summary>
                <div class="add-variable__form">
                    <input class="binding-row__select"
                           placeholder="variable_name"
                           value="@form.Name"
                           @onchange="args => SetFormName(node.Id, args)"
                           aria-label="New variable name" />
                    <select class="binding-row__select"
                            value="@form.Source"
                            @onchange="args => SetFormSource(node.Id, args)"
                            aria-label="New variable source">
                        <option value="">choose source…</option>
                        @foreach (var option in BindingSourceEditor.SourceOptions(Nodes, Scalars, node, string.Empty))
                        {
                            <option value="@option">@option</option>
                        }
                    </select>
                    <button type="button" class="add-variable__submit" @onclick="() => SubmitAddVariableAsync(node)">Add</button>
                </div>
                @if (form.Error != null)
                {
                    <p class="add-variable__error">@form.Error</p>
                }
            </details>
        }
    </article>
}

@foreach (var removedNode in (Only == null ? RemovedNodes : RemovedNodes.Where(n => n.Id == Only)))
{
    <article class="template-section template-section--removed">
        <div class="template-section__header">
            <div>
                <h3 class="panel-title"><span class="node-strike">@removedNode.Label</span> <span class="muted-text">— removed</span></h3>
                <p class="muted-text">@removedNode.Id · its prompt is removed with it</p>
            </div>
            <button type="button" class="add-variable__submit" @onclick="() => OnNodeRestored.InvokeAsync(removedNode.Id)">
                Restore
            </button>
        </div>
    </article>
}

@code {
    /// <summary>One effective binding row: current values plus the manifest's originals (null for pending-added variables).</summary>
    public sealed record BindingRow(string Variable, string From, string? As, string? OriginalFrom, string? OriginalAs, bool IsNew);

    public sealed record BindingChange(string NodeId, string Variable, string From, string? As);

    public sealed record VariableAdd(string NodeId, string Variable, string From, string? As);

    /// <summary>The node's full effective field tuple after one field changed (#117).</summary>
    public sealed record NodeChange(string NodeId, string Label, string? ForEach, string? OutputSchema, string? FailIfEmpty);

    /// <summary>An aggregator's full effective ordered source list after one change (#117).</summary>
    public sealed record AggregateChange(string NodeId, List<string> Sources);

    [Parameter] public IReadOnlyList<WorkflowManifestReader.NodeView> Nodes { get; set; } = Array.Empty<WorkflowManifestReader.NodeView>();
    [Parameter] public bool Editable { get; set; }
    [Parameter] public IReadOnlyList<string> Scalars { get; set; } = Array.Empty<string>();
    [Parameter] public IReadOnlyList<string> Collections { get; set; } = Array.Empty<string>();
    [Parameter] public IReadOnlyList<string> ContractOptions { get; set; } = Array.Empty<string>();
    [Parameter] public string? Only { get; set; }
    [Parameter] public Func<string, bool>? NodeModified { get; set; }
    [Parameter] public IReadOnlyList<WorkflowManifestReader.NodeView> RemovedNodes { get; set; } = Array.Empty<WorkflowManifestReader.NodeView>();
    [Parameter] public EventCallback<string> OnNodeRemoved { get; set; }
    [Parameter] public EventCallback<string> OnNodeRestored { get; set; }
    [Parameter] public Func<WorkflowManifestReader.NodeView, IReadOnlyList<BindingRow>>? RowsFor { get; set; }
    [Parameter] public Func<WorkflowManifestReader.NodeView, string, string?>? ValidateVariableName { get; set; }
    [Parameter] public EventCallback<BindingChange> OnBindingChanged { get; set; }
    [Parameter] public EventCallback<VariableAdd> OnVariableAdded { get; set; }
    [Parameter] public EventCallback<NodeChange> OnNodeChanged { get; set; }
    [Parameter] public EventCallback<AggregateChange> OnAggregateChanged { get; set; }

    private async Task MoveAggregateSourceAsync(WorkflowManifestReader.NodeView node, int index, int delta)
    {
        var sources = node.Aggregate!.ToList();
        (sources[index], sources[index + delta]) = (sources[index + delta], sources[index]);
        await OnAggregateChanged.InvokeAsync(new AggregateChange(node.Id, sources));
    }

    private async Task RemoveAggregateSourceAsync(WorkflowManifestReader.NodeView node, int index)
    {
        var sources = node.Aggregate!.ToList();
        sources.RemoveAt(index);
        await OnAggregateChanged.InvokeAsync(new AggregateChange(node.Id, sources));
    }

    private async Task AppendAggregateSourceAsync(WorkflowManifestReader.NodeView node, string? sourceRef)
    {
        if (string.IsNullOrEmpty(sourceRef) || node.Aggregate!.Contains(sourceRef))
        {
            return;
        }

        var sources = node.Aggregate!.ToList();
        sources.Add(sourceRef);
        await OnAggregateChanged.InvokeAsync(new AggregateChange(node.Id, sources));
    }

    private static string ForEachCollectionId(string forEach) =>
        forEach.StartsWith("data:", StringComparison.Ordinal) ? forEach["data:".Length..] : forEach;

    // Each field edit emits the node's complete effective tuple; the host
    // compares it against the manifest original (self-removing edits, like
    // binding rows). Selecting a value equal to the current one still emits —
    // harmlessly resolving to "no change" host-side.
    private async Task EmitNodeChangeAsync(
        WorkflowManifestReader.NodeView node,
        string? label = null,
        string? forEach = null,
        string? outputSchema = null,
        string? failIfEmpty = null)
    {
        var effectiveLabel = label ?? node.Label;
        var effectiveForEach = forEach != null ? (forEach.Length == 0 ? null : forEach) : node.ForEach;
        var effectiveSchema = outputSchema != null ? (outputSchema.Length == 0 ? null : outputSchema) : node.OutputSchema;
        var effectiveFailIfEmpty = failIfEmpty != null
            ? (failIfEmpty.Length == 0 ? null : failIfEmpty)
            : node.FailIfEmpty;

        // Dropping the contract drops its empty-output message too.
        if (effectiveSchema is null)
        {
            effectiveFailIfEmpty = null;
        }

        await OnNodeChanged.InvokeAsync(new NodeChange(node.Id, effectiveLabel, effectiveForEach, effectiveSchema, effectiveFailIfEmpty));
    }

    private sealed class AddForm
    {
        public string? Name { get; set; }
        public string Source { get; set; } = string.Empty;
        public string? Error { get; set; }
    }

    private readonly Dictionary<string, AddForm> addForms = new(StringComparer.Ordinal);

    private AddForm FormFor(string nodeId)
    {
        if (!addForms.TryGetValue(nodeId, out var form))
        {
            addForms[nodeId] = form = new AddForm();
        }

        return form;
    }

    private IReadOnlyList<BindingRow> Rows(WorkflowManifestReader.NodeView node) =>
        RowsFor?.Invoke(node)
            ?? node.Bindings.Select(b => new BindingRow(b.Variable, b.From, b.As, b.From, b.As, false)).ToList();

    private void SetFormName(string nodeId, ChangeEventArgs args) =>
        FormFor(nodeId).Name = args.Value?.ToString();

    private void SetFormSource(string nodeId, ChangeEventArgs args) =>
        FormFor(nodeId).Source = args.Value?.ToString() ?? string.Empty;

    private async Task SubmitAddVariableAsync(WorkflowManifestReader.NodeView node)
    {
        var form = FormFor(node.Id);
        var name = form.Name?.Trim() ?? string.Empty;
        form.Error = ValidateVariableName?.Invoke(node, name);

        if (form.Error != null)
        {
            return;
        }

        await OnVariableAdded.InvokeAsync(new VariableAdd(node.Id, name, form.Source, null));
        addForms.Remove(node.Id);
    }
}
