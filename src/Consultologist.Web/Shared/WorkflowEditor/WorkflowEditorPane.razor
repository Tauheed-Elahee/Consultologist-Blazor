@* The detail pane of the master–detail editor (#110): one selected text,
   editor and live preview side by side on wide screens. *@

<div class="pane-header">
    <div>
        <h3 class="panel-title">@Title</h3>
        <p class="muted-text">
            @Subtitle
            @if (Modified)
            {
                <strong> — edited</strong>
            }
        </p>
    </div>
    @if (HeaderActions != null)
    {
        <div class="pane-header__actions">@HeaderActions</div>
    }
</div>

@ChildContent

<div class="pane-split">
    <label class="input-field pane-editor">
        <span>@EditLabel</span>
        <FluentTextArea Value="@Text"
                        ValueChanged="@(async (string? value) => await TextChanged.InvokeAsync(value ?? string.Empty))"
                        Rows="18" />
    </label>
    <div class="pane-preview">
        <span class="muted-text">Preview</span>
        <div class="markdown-preview">
            @((MarkupString)MarkdownPreview.Render(Text))
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Subtitle { get; set; } = string.Empty;
    [Parameter] public string EditLabel { get; set; } = "Content";
    [Parameter] public string Text { get; set; } = string.Empty;
    [Parameter] public bool Modified { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? HeaderActions { get; set; }
    [Parameter] public EventCallback<string> TextChanged { get; set; }
}
