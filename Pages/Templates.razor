@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using System.Text.Json
@inject HttpClient Http
@attribute [Authorize]

@page "/templates"

<PageTitle>Templates</PageTitle>

<section class="page-header">
    <div class="page-header__content">
        <span class="section-eyebrow">Templates</span>
        <h1 class="page-title">Reusable consult structures.</h1>
        <p class="page-description">
            Template definitions keep generated notes consistent, reviewable, and aligned to the
            clinical context expected by each specialty.
        </p>
    </div>
</section>

<AuthorizeView>
    <Authorized>
        <section class="content-card">
            <div class="form-stack">
                <h2 class="panel-title">Consult note template</h2>
                <p class="panel-description">
                    The active template renders structured AI output into a physician-facing note.
                    Future template editing controls will use this same panel and form pattern.
                </p>
                <div class="state-panel">
                    <span class="muted-text">Current template</span>
                    <strong>templates/consult_template.scriban</strong>
                </div>
            </div>
        </section>
    </Authorized>
</AuthorizeView>

@code {
  [CascadingParameter]
  private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

  private JsonDocument? graphApiResponse = null;

  protected override async Task OnInitializedAsync()
  {
    var authState = await AuthenticationStateTask!;
    var user = authState.User;

    if (user.Identity?.IsAuthenticated == true)
    {
      try
      {
        using var response = await Http.GetAsync("https://graph.microsoft.com/v1.0/me");
        response.EnsureSuccessStatusCode();
        graphApiResponse = await response.Content.ReadFromJsonAsync<JsonDocument>().ConfigureAwait(false);
      }
      catch (AccessTokenNotAvailableException exception)
      {
        exception.Redirect();
      }
    }
  }
}
