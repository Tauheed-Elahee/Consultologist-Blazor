  private sealed class SseStreamState
  {
    public SseStreamState(string jobId)
    {
      JobId = jobId;
    }

    public string JobId { get; }
    public string? LatestEventId { get; private set; }
    public string? LatestEventType { get; private set; }
    public int EventCount { get; private set; }
    public bool ServerErrorEventSeen { get; set; }
    public bool TerminalEventSeen { get; private set; }

    public SseAttemptState StartAttempt()
    {
      return new SseAttemptState(JobId, Guid.NewGuid().ToString("D"));
    }

    public void RecordEvent(ConsultGenerationJobSseEvent jobEvent)
    {
      EventCount++;

      if (!string.IsNullOrWhiteSpace(jobEvent.EventId))
      {
        LatestEventId = jobEvent.EventId;
      }

      LatestEventType = jobEvent.EventName;

      if (jobEvent.EventName is "done" or "error")
      {
        TerminalEventSeen = true;
      }
    }
  }

  private sealed class SseAttemptState
  {
    private readonly Stopwatch stopwatch = Stopwatch.StartNew();

    public SseAttemptState(string jobId, string attemptId)
    {
      JobId = jobId;
      AttemptId = attemptId;
    }

    public string JobId { get; }
    public string AttemptId { get; }
    public string? LatestEventId { get; private set; }
    public string? LatestEventType { get; private set; }
    public int EventCount { get; private set; }
    public bool PollingFallbackStarted { get; set; }
    public bool PollingFallbackCompleted { get; set; }
    public bool ServerErrorEventSeen { get; set; }
    public bool TerminalExitReported { get; set; }
    public bool LifecycleExitReported { get; set; }
    public long ElapsedMs => stopwatch.ElapsedMilliseconds;

    public void RecordEvent(ConsultGenerationJobSseEvent jobEvent)
    {
      EventCount++;

      if (!string.IsNullOrWhiteSpace(jobEvent.EventId))
      {
        LatestEventId = jobEvent.EventId;
      }

      LatestEventType = jobEvent.EventName;
    }
  }

  public ValueTask DisposeAsync()
  {
    Navigation.LocationChanged -= HandleLocationChanged;
    CancelActiveEventStream("component-disposed");
    activeEventStreamCancellationTokenSource?.Dispose();
    return ValueTask.CompletedTask;
  }
}
