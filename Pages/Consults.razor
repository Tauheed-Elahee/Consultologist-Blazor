@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using System.Text
@using System.Text.Json
@using BlazorWasm.Services.AI
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IAIEndpointService AIService
@inject IJSRuntime JSRuntime
@inject ILogger<Consults> Logger
@inject IAccountEndpointService AccountService
@attribute [Authorize]
@implements IAsyncDisposable

@page "/consults"

<PageTitle>Consults</PageTitle>

<section class="page-header">
    <div class="page-header__content">
        <span class="section-eyebrow">Consults</span>
        <h1 class="page-title">Draft and review specialist consult notes.</h1>
        <p class="page-description">
            Paste the source consult draft and generate each note section from the active writing standards.
        </p>
    </div>
</section>

<AuthorizeView>
    <Authorized>
        <div class="consult-builder">
            <div class="consult-builder__input">
                <section class="workflow-panel">
                    <div class="form-stack">
                        <h2 class="panel-title">Consult details</h2>
                        <p class="panel-description">
                            Paste the referral, history, or draft note. Each output section uses this draft as the source of truth.
                        </p>

                        <label class="input-field">
                            <span>Consult draft</span>
                            <FluentTextArea @bind-Value="consultDraft"
                                            Placeholder="Enter referral details, clinical context, and the consult question..."
                                            Rows="16" />
                        </label>

                        <div class="action-row">
                            <FluentButton Appearance="Appearance.Accent"
                                          @onclick="CreateConsultAsync"
                                          Disabled="@(isStandardsLoading || isAiRequestLoading || string.IsNullOrWhiteSpace(consultDraft) || sectionStandards.Count == 0)">
                                Create consult
                            </FluentButton>
                        </div>
                    </div>
                </section>
            </div>

            <div class="consult-builder__output">
                <section class="workflow-panel">
                    <div class="form-stack">
                        <h2 class="panel-title">Section standards</h2>
                        <p class="panel-description">
                            The active standards are loaded from browser storage, with bundled defaults as the fallback.
                        </p>

                        <div class="state-panel">
                            <span class="muted-text">Sections loaded</span>
                            <strong>@generatedSections.Count/@sectionStandards.Count</strong>
                        </div>
                    </div>
                </section>

                <section class="result-panel consult-builder__result">
                    <div class="consult-status">
                        @if (isStandardsLoading)
                        {
                            <div class="loading-state">
                                <FluentProgressRing />
                                <span>Loading section standards...</span>
                            </div>
                        }

                        @if (isAiRequestLoading)
                        {
                            <div class="loading-state">
                                <FluentProgressRing />
                                <span>Generating @completedSectionCount/@totalSectionCount sections...</span>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(standardsLoadError))
                        {
                            <FluentMessageBar Intent="MessageIntent.Error">@standardsLoadError</FluentMessageBar>
                        }

                        @if (!string.IsNullOrEmpty(aiRequestError))
                        {
                            <FluentMessageBar Intent="MessageIntent.Error">@aiRequestError</FluentMessageBar>
                        }

                        @if (!string.IsNullOrEmpty(aiProgressNotice))
                        {
                            <FluentMessageBar Intent="MessageIntent.Info">@aiProgressNotice</FluentMessageBar>
                        }

                        @if (generatedSections.Count > 0)
                        {
                            <div>
                                <div class="result-header">
                                    <h2 class="panel-title">Consultation note</h2>
                                    <FluentBadge Appearance="Appearance.Accent">
                                        @generatedSections.Count sections
                                    </FluentBadge>
                                </div>

                                <article class="note-preview generated-note">
                                    @foreach (var standard in sectionStandards)
                                    {
                                        if (generatedSections.TryGetValue(standard.Id, out var prose) && !string.IsNullOrWhiteSpace(prose))
                                        {
                                            <section class="note-section">
                                                <h3>@standard.Name</h3>
                                                <p>@prose</p>
                                            </section>
                                        }
                                    }
                                </article>
                            </div>
                        }
                        else if (!isStandardsLoading && !isAiRequestLoading && string.IsNullOrEmpty(standardsLoadError) && string.IsNullOrEmpty(aiRequestError))
                        {
                            <div class="empty-note-state">
                                <h2 class="panel-title">Consultation note</h2>
                                <p class="panel-description">
                                    Generated consult sections will appear here after you enter a draft and create the consult.
                                </p>
                            </div>
                        }
                    </div>
                </section>
            </div>
        </div>
    </Authorized>
</AuthorizeView>

@code {
  private const string StandardsPath = "templates/consult_section_standards.md";
  private const string StorageKeyPrefix = "consultologist.consultSectionStandards.v1";
  private static readonly JsonSerializerOptions SseJsonOptions = new()
  {
    PropertyNameCaseInsensitive = true
  };

  [CascadingParameter]
  private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

  private AccountMeResponse? account;
  private string consultDraft = string.Empty;
  private List<SectionStandard> sectionStandards = new();
  private Dictionary<string, string> generatedSections = new();
  private Dictionary<string, string> failedSectionErrors = new();
  private bool isStandardsLoading;
  private string? standardsLoadError;
  private bool isAiRequestLoading;
  private string? aiRequestError;
  private string? aiProgressNotice;
  private int completedSectionCount;
  private int totalSectionCount;
  private CancellationTokenSource? activeEventStreamCancellationTokenSource;
  private IReadOnlyList<SectionStandard> activeSectionSnapshots = Array.Empty<SectionStandard>();

  protected override async Task OnInitializedAsync()
  {
    await LoadAccountAsync();
    await LoadSectionStandardsAsync();
  }

  private async Task LoadAccountAsync()
  {
    var authState = await AuthenticationStateTask!;
    var user = authState.User;

    if (user.Identity?.IsAuthenticated != true)
    {
      return;
    }

    try
    {
      account = await AccountService.GetCurrentAccountAsync();
    }
    catch (AccessTokenNotAvailableException exception)
    {
      exception.Redirect();
    }
    catch (Exception ex)
    {
      standardsLoadError = $"Unable to load account information: {ex.Message}";
    }
  }

  private async Task LoadSectionStandardsAsync()
  {
    isStandardsLoading = true;
    standardsLoadError = null;

    try
    {
      var storedMarkdown = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", GetStorageKey());
      var markdown = string.IsNullOrWhiteSpace(storedMarkdown)
        ? await LoadBundledStandardsAsync()
        : storedMarkdown;

      sectionStandards = ParseStandards(markdown);
    }
    catch (Exception ex)
    {
      sectionStandards = new();
      standardsLoadError = $"Unable to load section standards: {ex.Message}";
    }
    finally
    {
      isStandardsLoading = false;
    }
  }

  private async Task CreateConsultAsync()
  {
    aiRequestError = null;
    aiProgressNotice = null;
    generatedSections = new();
    failedSectionErrors = new();
    completedSectionCount = 0;
    totalSectionCount = 0;

    if (string.IsNullOrWhiteSpace(consultDraft))
    {
      aiRequestError = "Consult draft is required.";
      return;
    }

    if (sectionStandards.Count == 0)
    {
      aiRequestError = "No section standards are available.";
      return;
    }

    try
    {
      isAiRequestLoading = true;
      var draftSnapshot = consultDraft;
      var sectionSnapshots = sectionStandards.ToList();
      totalSectionCount = sectionSnapshots.Count;
      await InvokeAsync(StateHasChanged);

      var requestSections = sectionSnapshots
        .Select(section => new ConsultGenerationSectionRequest(section.Id, section.Name, section.Standard))
        .ToList();

      var job = await AIService.StartConsultGenerationJobAsync(draftSnapshot, requestSections);
      var streamResult = await StreamConsultGenerationJobAsync(job.JobId, sectionSnapshots);

      if (streamResult == ConsultGenerationStreamResult.FallbackToPolling && isAiRequestLoading)
      {
        Logger.LogWarning(
          "Consult generation falling back to polling. JobId={JobId}, CompletedCount={CompletedCount}, FailedCount={FailedCount}, TotalCount={TotalCount}",
          job.JobId,
          generatedSections.Count,
          failedSectionErrors.Count,
          totalSectionCount);

        aiProgressNotice = "Live updates paused; checking status periodically.";
        await InvokeAsync(StateHasChanged);
        await PollConsultGenerationJobAsync(job.JobId, sectionSnapshots);
      }
    }
    catch (Exception ex)
    {
      aiRequestError = $"Error calling agent: {ex.Message}";
    }
    finally
    {
      isAiRequestLoading = false;
    }
  }

  private async Task<ConsultGenerationStreamResult> StreamConsultGenerationJobAsync(
    string jobId,
    IReadOnlyList<SectionStandard> sectionSnapshots)
  {
    activeSectionSnapshots = sectionSnapshots;

    const int streamTimeoutMinutes = 10;
    using var timeoutCancellationTokenSource = new CancellationTokenSource(TimeSpan.FromMinutes(streamTimeoutMinutes));
    activeEventStreamCancellationTokenSource = timeoutCancellationTokenSource;

    try
    {
      Logger.LogInformation(
        "Opening consult generation SSE stream. JobId={JobId}, SectionCount={SectionCount}",
        jobId,
        sectionSnapshots.Count);

      await foreach (var jobEvent in AIService.StreamConsultGenerationJobEventsAsync(jobId, timeoutCancellationTokenSource.Token))
      {
        var eventResult = await HandleConsultGenerationJobEventAsync(jobEvent.EventName, jobEvent.Json);

        if (eventResult == ConsultGenerationEventResult.Completed)
        {
          return ConsultGenerationStreamResult.Completed;
        }

        if (eventResult == ConsultGenerationEventResult.FallbackToPolling)
        {
          return ConsultGenerationStreamResult.FallbackToPolling;
        }
      }

      Logger.LogWarning(
        "Consult generation SSE stream ended before done. JobId={JobId}",
        jobId);

      return ConsultGenerationStreamResult.FallbackToPolling;
    }
    catch (OperationCanceledException) when (timeoutCancellationTokenSource.IsCancellationRequested)
    {
      Logger.LogWarning(
        "Consult generation SSE stream timed out before completion. JobId={JobId}, TimeoutMinutes={TimeoutMinutes}",
        jobId,
        streamTimeoutMinutes);

      return ConsultGenerationStreamResult.FallbackToPolling;
    }
    catch (Exception ex)
    {
      Logger.LogWarning(
        ex,
        "Consult generation SSE stream setup failed. JobId={JobId}",
        jobId);

      return ConsultGenerationStreamResult.FallbackToPolling;
    }
    finally
    {
      if (ReferenceEquals(activeEventStreamCancellationTokenSource, timeoutCancellationTokenSource))
      {
        activeEventStreamCancellationTokenSource = null;
      }

      activeSectionSnapshots = Array.Empty<SectionStandard>();
    }
  }

  private async Task PollConsultGenerationJobAsync(string jobId, IReadOnlyList<SectionStandard> sectionSnapshots)
  {
    try
    {
      while (isAiRequestLoading)
      {
        var response = await AIService.GetConsultGenerationJobAsync(jobId);

        ApplyConsultGenerationJobResponse(response, sectionSnapshots);
        await InvokeAsync(StateHasChanged);

        if (response.Status is "Completed" or "Failed")
        {
          aiProgressNotice = null;
          return;
        }

        await Task.Delay(TimeSpan.FromSeconds(2));
      }
    }
    catch (Exception ex)
    {
      aiProgressNotice = null;
      aiRequestError = $"Error checking consult generation status: {ex.Message}";
    }
  }

  private async Task<ConsultGenerationEventResult> HandleConsultGenerationJobEventAsync(string eventName, string json)
  {
    try
    {
      switch (eventName)
      {
        case "snapshot":
          var snapshot = JsonSerializer.Deserialize<ConsultGenerationJobResponse>(json, SseJsonOptions);
          if (snapshot != null)
          {
            Logger.LogInformation(
              "Consult generation SSE snapshot received. JobId={JobId}, Status={Status}, TotalCount={TotalCount}, CompletedCount={CompletedCount}, FailedCount={FailedCount}",
              snapshot.JobId,
              snapshot.Status,
              snapshot.TotalSectionCount,
              snapshot.CompletedSectionCount,
              snapshot.FailedSectionCount);

            ApplyConsultGenerationJobResponse(snapshot, GetActiveSectionSnapshots());
          }
          break;

        case "section-completed":
          var completed = JsonSerializer.Deserialize<ConsultGenerationSectionCompletedEvent>(json, SseJsonOptions);
          if (completed != null)
          {
            generatedSections = new Dictionary<string, string>(generatedSections)
            {
              [completed.SectionId] = completed.Text
            };
            var nextFailedSections = new Dictionary<string, string>(failedSectionErrors);
            nextFailedSections.Remove(completed.SectionId);
            failedSectionErrors = nextFailedSections;
            completedSectionCount = generatedSections.Count + failedSectionErrors.Count;
          }
          break;

        case "section-failed":
          var failed = JsonSerializer.Deserialize<ConsultGenerationSectionFailedEvent>(json, SseJsonOptions);
          if (failed != null)
          {
            failedSectionErrors = new Dictionary<string, string>(failedSectionErrors)
            {
              [failed.SectionId] = failed.Error
            };
            var nextGeneratedSections = new Dictionary<string, string>(generatedSections);
            nextGeneratedSections.Remove(failed.SectionId);
            generatedSections = nextGeneratedSections;
            completedSectionCount = generatedSections.Count + failedSectionErrors.Count;
            UpdateFailedSectionError(GetActiveSectionSnapshots());
          }
          break;

        case "analysis-started":
        case "concepts-extracted":
        case "problem-identified":
        case "typical-trajectory-created":
        case "patient-trajectory-created":
        case "section-generation-started":
          var stage = JsonSerializer.Deserialize<ConsultGenerationStageEvent>(json, SseJsonOptions);
          aiProgressNotice = GetConsultGenerationProgressLabel(stage?.Stage ?? eventName);
          break;

        case "section-standard-draft-created":
        case "section-patient-draft-created":
        case "section-instructions-applied":
          var sectionStep = JsonSerializer.Deserialize<ConsultGenerationSectionProseStepEvent>(json, SseJsonOptions);
          if (sectionStep != null)
          {
            aiProgressNotice = $"{GetSectionProseStepProgressLabel(sectionStep.Step)}: {sectionStep.SectionName}";
          }
          break;

        case "done":
          var final = JsonSerializer.Deserialize<ConsultGenerationJobResponse>(json, SseJsonOptions);
          if (final != null)
          {
            Logger.LogInformation(
              "Consult generation SSE done received. JobId={JobId}, Status={Status}, TotalCount={TotalCount}, CompletedCount={CompletedCount}, FailedCount={FailedCount}",
              final.JobId,
              final.Status,
              final.TotalSectionCount,
              final.CompletedSectionCount,
              final.FailedSectionCount);

            ApplyConsultGenerationJobResponse(final, GetActiveSectionSnapshots());
          }

          await InvokeAsync(StateHasChanged);
          return ConsultGenerationEventResult.Completed;

        case "error":
          var error = JsonSerializer.Deserialize<ConsultGenerationErrorEvent>(json, SseJsonOptions);
          if (error != null && IsPreprocessingFailureStage(error.Stage))
          {
            aiProgressNotice = null;
            aiRequestError = error.Error;
            isAiRequestLoading = false;
            await InvokeAsync(StateHasChanged);
            return ConsultGenerationEventResult.Completed;
          }

          Logger.LogWarning(
            "Consult generation SSE error event received. PayloadLength={PayloadLength}",
            json.Length);

          return ConsultGenerationEventResult.FallbackToPolling;
      }

      await InvokeAsync(StateHasChanged);
      return ConsultGenerationEventResult.Continue;
    }
    catch
    {
      Logger.LogWarning(
        "Consult generation SSE event handling failed. EventName={EventName}, PayloadLength={PayloadLength}",
        eventName,
        json.Length);

      return ConsultGenerationEventResult.FallbackToPolling;
    }
  }

  private void ApplyConsultGenerationJobResponse(
    ConsultGenerationJobResponse response,
    IReadOnlyList<SectionStandard> sectionSnapshots)
  {
    generatedSections = response.GeneratedSections;
    failedSectionErrors = response.FailedSections;
    totalSectionCount = response.TotalSectionCount == 0 ? sectionSnapshots.Count : response.TotalSectionCount;
    completedSectionCount = response.CompletedSectionCount + response.FailedSectionCount;

    if (!string.IsNullOrWhiteSpace(response.AnalysisStatus)
        && response.Status != "Failed"
        && !IsPreprocessingFailureStage(response.AnalysisStatus))
    {
      aiProgressNotice = GetConsultGenerationProgressLabel(response.AnalysisStatus);
    }

    if (response.Status == "Failed" && !string.IsNullOrWhiteSpace(response.AnalysisError))
    {
      aiProgressNotice = null;
      aiRequestError = response.AnalysisError;
      return;
    }

    UpdateFailedSectionError(sectionSnapshots);
  }

  private static bool IsPreprocessingFailureStage(string? stage)
  {
    return !string.IsNullOrWhiteSpace(stage)
      && stage.EndsWith("-failed", StringComparison.Ordinal);
  }

  private static string GetConsultGenerationProgressLabel(string stage)
  {
    return stage switch
    {
      "analysis-started" => "Analyzing draft",
      "concepts-extracted" => "Extracting clinical concepts",
      "problem-identified" => "Identifying primary problem",
      "typical-trajectory-created" => "Building reference trajectory",
      "patient-trajectory-created" => "Building patient trajectory",
      "section-generation-started" => "Generating sections",
      _ => "Generating consult"
    };
  }

  private static string GetSectionProseStepProgressLabel(string step)
  {
    return step switch
    {
      "section-standard-draft-created" => "Drafting section",
      "section-patient-draft-created" => "Applying patient information",
      "section-instructions-applied" => "Applying section instructions",
      _ => "Generating section"
    };
  }

  private void UpdateFailedSectionError(IReadOnlyList<SectionStandard> sectionSnapshots)
  {
    if (failedSectionErrors.Count == 0)
    {
      if (aiRequestError?.StartsWith("Unable to generate:", StringComparison.Ordinal) == true)
      {
        aiRequestError = null;
      }

      return;
    }

    var failedSectionNames = sectionSnapshots
      .Where(section => failedSectionErrors.ContainsKey(section.Id))
      .Select(section => section.Name);

    aiRequestError = $"Unable to generate: {string.Join(", ", failedSectionNames)}.";
  }

  private IReadOnlyList<SectionStandard> GetActiveSectionSnapshots()
  {
    return activeSectionSnapshots.Count > 0
      ? activeSectionSnapshots
      : sectionStandards;
  }

  private async Task<string> LoadBundledStandardsAsync()
  {
    var standardsUri = new Uri(new Uri(Navigation.BaseUri), StandardsPath);
    return await Http.GetStringAsync(standardsUri);
  }

  private string GetStorageKey()
  {
    return account == null
      ? $"{StorageKeyPrefix}:anonymous"
      : $"{StorageKeyPrefix}:{account.AppUserId}";
  }

  private static List<SectionStandard> ParseStandards(string markdown)
  {
    var sections = new List<SectionStandard>();
    SectionStandard? current = null;
    var content = new StringBuilder();

    foreach (var line in markdown.Replace("\r\n", "\n").Split('\n'))
    {
      if (line.StartsWith("## ", StringComparison.Ordinal))
      {
        if (current != null)
        {
          current.Standard = content.ToString().Trim();
          sections.Add(current);
          content.Clear();
        }

        var heading = line[3..].Trim();
        var separatorIndex = heading.IndexOf(':');
        var id = separatorIndex >= 0 ? heading[..separatorIndex].Trim() : CreateId(heading);
        var name = separatorIndex >= 0 ? heading[(separatorIndex + 1)..].Trim() : heading;
        current = new SectionStandard(id, name, string.Empty);
        continue;
      }

      if (current != null)
      {
        content.AppendLine(line);
      }
    }

    if (current != null)
    {
      current.Standard = content.ToString().Trim();
      sections.Add(current);
    }

    return sections;
  }

  private static string CreateId(string value)
  {
    return value.Trim().ToLowerInvariant().Replace(' ', '_');
  }

  private sealed class SectionStandard
  {
    public SectionStandard(string id, string name, string standard)
    {
      Id = id;
      Name = name;
      Standard = standard;
    }

    public string Id { get; }
    public string Name { get; }
    public string Standard { get; set; }
  }

  private sealed record ConsultGenerationSectionCompletedEvent(
    string JobId,
    string SectionId,
    string Text);

  private sealed record ConsultGenerationSectionFailedEvent(
    string JobId,
    string SectionId,
    string Error);

  private sealed record ConsultGenerationStageEvent(
    string JobId,
    string Stage,
    string Message,
    int CompletedStageCount,
    int TotalStageCount);

  private sealed record ConsultGenerationSectionProseStepEvent(
    string JobId,
    string SectionId,
    string SectionName,
    string Step,
    string Message,
    int CompletedStepCount,
    int TotalStepCount);

  private sealed record ConsultGenerationErrorEvent(
    string JobId,
    string Error,
    string? Stage);

  private enum ConsultGenerationStreamResult
  {
    Completed,
    FallbackToPolling
  }

  private enum ConsultGenerationEventResult
  {
    Continue,
    Completed,
    FallbackToPolling
  }

  public ValueTask DisposeAsync()
  {
    activeEventStreamCancellationTokenSource?.Cancel();
    activeEventStreamCancellationTokenSource?.Dispose();
    return ValueTask.CompletedTask;
  }
}
