{
	"version": "2.0",
	"logging": {
		"logLevel": {
			"default": "Information",
			"Function": "Information",
			"Host.Results": "Information",
			"Worker": "Debug",
			"Microsoft.Azure.Functions.Worker": "Debug",
			"Microsoft.Azure.WebJobs.Extensions.DurableTask": "Error",
			"Host.Triggers.DurableTask": "Error",
			"Azure.Core": "Warning",
			"Azure.Storage": "Warning",
			"Azure.Data.Tables": "Warning",
			"Api.InvocationDiagnostics": "Information"
		},
		"applicationInsights": {
			"samplingSettings": {
				"isEnabled": true,
				"excludedTypes": "Request"
			},
			"enableLiveMetricsFilters": true
		}
	},
	"extensions": {
		"durableTask": {
			"hubName": "consultologistjobs"
		}
	},
	"functionHttpApi": {
		"enableCors": true,
		"corsPolicy": {
			"allowedOrigins": [
				"https://app.consultologist.ai",
				"https://gentle-desert-09697700f.3.azurestaticapps.net"
			],
			"allowedMethods": ["GET", "POST", "OPTIONS"],
			"allowedHeaders": ["Content-Type", "Authorization"]
		}
	}
}
